---
/**
 * ArticleLayout.astro
 * Layout for educational guides and blog posts.
 * Implements full E-E-A-T signals per the Seniors Audit Master Spec:
 * - Author (T. Emmanuel or U. Simon James with consistent naming)
 * - Last Updated date
 * - Estimated reading time
 * - Sources
 * - Related articles
 * - Related tools
 * - Breadcrumbs, Table of Contents, Legal Disclaimer
 */

import BaseLayout from './BaseLayout.astro';
import Breadcrumb from '@components/common/Breadcrumb.astro';
import TableOfContents from '@components/content/TableOfContents.astro';
import AuthorBio from '@components/content/AuthorBio.astro';
import DisclaimerBlock from '@components/content/DisclaimerBlock.astro';
import RelatedArticles from '@components/content/RelatedArticles.astro';

interface Source {
  label: string;
  url: string;
}

interface RelatedTool {
  title: string;
  href: string;
}

interface RelatedArticleItem {
  title: string;
  href: string;
  description?: string;
}

interface Props {
  frontmatter: {
    title: string;
    description: string;
    category: string;
    publishDate: Date;
    updatedDate?: Date;
    author?: 'emmanuel' | 'simon';   // defaults to 'emmanuel'
    wordCount?: number;              // optional override for reading time
    tags?: string[];
    sources?: Source[];
    relatedTools?: RelatedTool[];
  };
  headings: any[];
  relatedArticles?: RelatedArticleItem[];
}

const { frontmatter, headings, relatedArticles = [] } = Astro.props;

const authorKey: 'emmanuel' | 'simon' =
  frontmatter.author === 'simon' ? 'simon' : 'emmanuel';

// Author display info consistent with the Master Spec
const authorInfo = {
  emmanuel: {
    displayName: 'T. Emmanuel',
    fullName:    'TUYISHIMIRE Emmanuel',
    profileUrl:  'https://www.seniorsaudit.com/about/emmanuel-t/',
  },
  simon: {
    displayName: 'U. Simon James',
    fullName:    'UWUMUKIZA Simon James',
    profileUrl:  'https://www.seniorsaudit.com/about/',
  },
};
const person = authorInfo[authorKey];

const categoryUrlMap: Record<string, string> = {
  'irs':            '/irs/',
  'social-security': '/social-security/',
  'medicare':       '/medicare/',
  'medicaid':       '/medicaid/',
  'retirement':     '/retirement/',
  'taxes':          '/taxes/',
  'blog':           '/blog/',
};

const formattedDate = new Date(frontmatter.publishDate).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});

const formattedUpdatedDate = frontmatter.updatedDate
  ? new Date(frontmatter.updatedDate).toLocaleDateString('en-US', {
      year: 'numeric', month: 'long', day: 'numeric',
    })
  : null;

// Estimate reading time: ~200 words per minute for seniors-friendly reading pace
const wordCount = frontmatter.wordCount ?? 1800; // conservative default
const readingMinutes = Math.ceil(wordCount / 200);
const readingTimeLabel = readingMinutes === 1 ? '1 minute read' : `${readingMinutes} minute read`;

const breadcrumbItems = [
  { label: frontmatter.category.replace('-', ' '), href: categoryUrlMap[frontmatter.category] || '/' },
  { label: frontmatter.title },
];

const siteUrl = 'https://www.seniorsaudit.com';

// Article JSON-LD schema
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": frontmatter.title,
  "description": frontmatter.description,
  "datePublished": frontmatter.publishDate.toISOString(),
  "dateModified": (frontmatter.updatedDate ?? frontmatter.publishDate).toISOString(),
  "author": {
    "@type": "Person",
    "name": person.displayName,
    "alternateName": person.fullName,
    "url": person.profileUrl,
  },
  "publisher": {
    "@type": "Organization",
    "@id": `${siteUrl}/#organization`,
    "name": "Seniors Audit",
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/apple-touch-icon.png`,
    },
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `${siteUrl}${Astro.url.pathname}`,
  },
  "image": {
    "@type": "ImageObject",
    "url": `${siteUrl}/images/og-default.jpg`,
    "width": 1200,
    "height": 630,
  },
  "url": `${siteUrl}${Astro.url.pathname}`,
};
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  ogType="article"
  articleAuthor={person.displayName}
  articlePublishedTime={frontmatter.publishDate.toISOString()}
  articleModifiedTime={(frontmatter.updatedDate ?? frontmatter.publishDate).toISOString()}
  schema={articleSchema}
>
  <article class="article-layout-container">
    <div class="container">

      <!-- Breadcrumbs -->
      <Breadcrumb items={breadcrumbItems} />

      <div class="article-grid">

        <!-- Main Column -->
        <div class="article-main">
          <header class="article-header">
            <span class="article-category-badge">{frontmatter.category.replace('-', ' ')}</span>
            <h1 class="article-title">{frontmatter.title}</h1>

            <!-- Author + Date + Reading Time row -->
            <div class="article-byline">
              <div class="byline-author">
                <img
                  src={authorKey === 'emmanuel' ? '/Emmanuel.png' : '/simon.png'}
                  alt={person.fullName}
                  class="byline-photo"
                  width="36"
                  height="36"
                  loading="eager"
                  decoding="async"
                  onerror="this.style.display='none';"
                />
                <div class="byline-text">
                  <span class="byline-written-by">Written by</span>
                  <a href={person.profileUrl} class="byline-name" rel="author">
                    {person.displayName}
                    <span class="byline-fullname">({person.fullName})</span>
                  </a>
                </div>
              </div>
              <div class="byline-meta">
                <span class="byline-date">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                  Published: {formattedDate}
                </span>
                {formattedUpdatedDate && (
                  <span class="byline-updated">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 2v6h-6"/><path d="M3 12a9 9 0 0 1 15-6.7L21 8"/><path d="M3 22v-6h6"/><path d="M21 12a9 9 0 0 1-15 6.7L3 16"/></svg>
                    Updated: {formattedUpdatedDate}
                  </span>
                )}
                <span class="byline-readtime">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  {readingTimeLabel}
                </span>
              </div>
            </div>
          </header>

          <!-- Table of Contents for Mobile (Stacked) -->
          <div class="toc-mobile no-print">
            <TableOfContents headings={headings} />
          </div>

          <!-- Article body -->
          <div class="article-body">
            <slot />
          </div>

          <!-- Official Sources -->
          {frontmatter.sources && frontmatter.sources.length > 0 && (
            <section class="article-sources" aria-labelledby="sources-heading">
              <h2 id="sources-heading" class="sources-title">Official Sources</h2>
              <ul class="sources-list" role="list">
                {frontmatter.sources.map((src: Source) => (
                  <li>
                    <a
                      href={src.url}
                      class="source-link"
                      target="_blank"
                      rel="noopener noreferrer nofollow"
                    >
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
                      {src.label}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}

          <!-- Related Tools -->
          {frontmatter.relatedTools && frontmatter.relatedTools.length > 0 && (
            <section class="article-related-tools" aria-labelledby="related-tools-heading">
              <h2 id="related-tools-heading" class="related-tools-title">Related Calculators &amp; Tools</h2>
              <ul class="related-tools-list" role="list">
                {frontmatter.relatedTools.map((tool: RelatedTool) => (
                  <li>
                    <a href={tool.href} class="related-tool-link">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/></svg>
                      {tool.title}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}

          <!-- Bottom: Author Bio card + Disclaimer -->
          <footer class="article-footer">
            <DisclaimerBlock type="article" />
            <AuthorBio author={authorKey} />
          </footer>
        </div>

        <!-- Sidebar (Desktop only) -->
        <aside class="article-sidebar no-print" aria-label="Article Outline">
          <div class="sticky-sidebar">
            <TableOfContents headings={headings} />
          </div>
        </aside>

      </div>

      <!-- Related Articles -->
      {relatedArticles.length > 0 && (
        <RelatedArticles articles={relatedArticles} />
      )}

    </div>
  </article>
</BaseLayout>

<style>
  .article-layout-container {
    padding-block: var(--space-8);
  }

  .article-header {
    margin-bottom: var(--space-6);
  }

  .article-category-badge {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-secondary);
    margin-bottom: var(--space-2);
  }

  .article-title {
    font-size: var(--text-3xl);
    color: var(--color-primary);
    margin-bottom: var(--space-4);
    line-height: var(--leading-tight);
  }

  /* Byline */
  .article-byline {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    gap: var(--space-4);
    padding: var(--space-4);
    background-color: var(--color-surface-alt);
    border-left: 3px solid var(--color-secondary);
    border-radius: var(--radius-md);
    margin-bottom: var(--space-2);
  }

  .byline-author {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .byline-photo {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    object-fit: cover;
    border: 2px solid var(--color-secondary);
    flex-shrink: 0;
  }

  .byline-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .byline-written-by {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    font-weight: var(--font-bold);
  }

  .byline-name {
    font-size: var(--text-base);
    font-weight: var(--font-bold);
    color: var(--color-primary);
    text-decoration: none;
  }

  .byline-name:hover {
    text-decoration: underline;
    color: var(--color-secondary);
  }

  .byline-fullname {
    font-size: var(--text-sm);
    font-weight: var(--font-normal);
    color: var(--color-text-muted);
    font-style: italic;
  }

  .byline-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .byline-date,
  .byline-updated,
  .byline-readtime {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
  }

  .byline-updated {
    color: var(--color-secondary-dark);
    font-weight: var(--font-bold);
  }

  /* Grid */
  .article-grid {
    display: grid;
    grid-template-columns: 2.2fr 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  @media (max-width: 960px) {
    .article-grid {
      grid-template-columns: 1fr;
    }

    .article-sidebar {
      display: none;
    }
  }

  @media (min-width: 961px) {
    .toc-mobile {
      display: none;
    }
  }

  /* Body */
  .article-body {
    line-height: var(--leading-relaxed);
    color: var(--color-text);
  }

  .article-body :global(p) {
    margin-bottom: var(--space-5);
  }

  .article-body :global(h2) {
    font-size: var(--text-2xl);
    color: var(--color-primary);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
  }

  .article-body :global(h3) {
    font-size: var(--text-xl);
    color: var(--color-primary-light);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin-bottom: var(--space-6);
    padding-left: var(--space-6);
  }

  .article-body :global(li) {
    margin-bottom: var(--space-2);
  }

  /* Sources */
  .article-sources {
    margin-top: var(--space-10);
    padding: var(--space-5) var(--space-6);
    background-color: hsl(210, 20%, 97%);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-lg);
  }

  .sources-title {
    font-size: var(--text-lg);
    color: var(--color-primary);
    margin: 0 0 var(--space-4) 0;
  }

  .sources-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .source-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-base);
    color: var(--color-secondary-dark);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .source-link:hover {
    color: var(--color-primary);
  }

  /* Related Tools */
  .article-related-tools {
    margin-top: var(--space-8);
    padding: var(--space-5) var(--space-6);
    background-color: hsl(186, 20%, 97%);
    border: 1.5px solid var(--color-secondary);
    border-radius: var(--radius-lg);
  }

  .related-tools-title {
    font-size: var(--text-lg);
    color: var(--color-primary);
    margin: 0 0 var(--space-4) 0;
  }

  .related-tools-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .related-tool-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-base);
    font-weight: var(--font-bold);
    color: var(--color-secondary-dark);
    text-decoration: none;
  }

  .related-tool-link:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  /* Sidebar */
  .sticky-sidebar {
    position: sticky;
    top: calc(var(--header-height) + var(--space-6));
  }

  /* Footer */
  .article-footer {
    margin-top: var(--space-10);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-6);
  }
</style>
