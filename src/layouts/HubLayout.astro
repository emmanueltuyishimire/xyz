---
/**
 * HubLayout.astro — Topic Hub Page Layout
 * seniorsaudit.com
 *
 * Purpose: Authoritative hub page for a topic cluster (e.g. /medicare/, /medicare/enrollment/).
 * Designed for topical authority: hub-and-spoke SEO structure, MedicalWebPage JSON-LD,
 * WCAG 2.2 AA compliance, senior-optimised typography (18px minimum), sticky sidebar TOC.
 *
 * Schema: MedicalWebPage + optional FAQPage JSON-LD
 */

import BaseLayout from '@layouts/BaseLayout.astro';

export interface ArticleCard {
  title: string;
  description: string;
  href: string;
  readingTime?: number;
  isNew?: boolean;
  tag?: string; // e.g. "Most Popular", "Updated"
}

export interface ToolCard {
  title: string;
  description: string;
  href: string;
  icon?: 'calculator' | 'checklist' | 'compare' | 'clock' | 'dollar';
}

export interface FAQItem {
  question: string;
  answer: string;
}

export interface HubSection {
  id: string;
  heading: string;
  content: string; // Rich HTML string
}

export interface RelatedHub {
  title: string;
  description: string;
  href: string;
}

interface Props {
  // SEO & Meta
  pageTitle: string;
  description: string;
  canonicalPath: string;    // e.g. "medicare/enrollment"
  ogImage?: string;

  // Page Content
  h1: string;
  quickAnswer: string;      // ≤ 60 words, for featured snippet
  leadParagraph: string;    // 80–100 words, peer-tone problem statement
  whatThisCovers: string[]; // 4–6 bullet questions

  // Structured Content
  sections?: HubSection[];  // Written body sections rendered in main column

  // Article cards shown in hub
  articles: ArticleCard[];

  // Tool cards shown in hub
  tools?: ToolCard[];

  // FAQ items
  faqs?: FAQItem[];

  // Sidebar TOC (auto-generated from sections + headings if omitted)
  tocItems?: { id: string; label: string }[];

  // Related hubs (cross-linking)
  relatedHubs?: RelatedHub[];

  // Trust / Schema
  breadcrumbs: { name: string; url: string }[];
  lastUpdated: string;      // ISO date "2026-07-15"
  primaryKeyword: string;
  authorName?: string;
  sourcesList?: { name: string; url: string }[];
}

const {
  pageTitle,
  description,
  canonicalPath,
  ogImage = '/og-default.jpg',
  h1,
  quickAnswer,
  leadParagraph,
  whatThisCovers,
  sections = [],
  articles,
  tools = [],
  faqs = [],
  tocItems,
  relatedHubs = [],
  breadcrumbs,
  lastUpdated,
  primaryKeyword,
  authorName = 'Seniors Audit Research Team',
  sourcesList = [],
} = Astro.props;

// Build Table of Contents from sections prop OR tocItems prop
const toc = tocItems ?? [
  ...sections.map(s => ({ id: s.id, label: s.heading })),
  ...(articles.length > 0 ? [{ id: 'articles', label: 'All Guides in This Section' }] : []),
  ...(tools.length > 0 ? [{ id: 'tools', label: 'Free Calculators & Tools' }] : []),
  ...(faqs.length > 0 ? [{ id: 'faqs', label: 'Frequently Asked Questions' }] : []),
];

// MedicalWebPage schema
const hubSchemas: object[] = [
  {
    '@context': 'https://schema.org',
    '@type': 'MedicalWebPage',
    '@id': `https://www.seniorsaudit.com/${canonicalPath}/#webpage`,
    name: h1,
    description,
    url: `https://www.seniorsaudit.com/${canonicalPath}/`,
    isPartOf: { '@id': 'https://seniorsaudit.com/#website' },
    about: {
      '@type': 'Thing',
      name: primaryKeyword,
    },
    author: { '@id': 'https://seniorsaudit.com/#organization' },
    publisher: { '@id': 'https://seniorsaudit.com/#organization' },
    dateModified: lastUpdated,
    inLanguage: 'en-US',
    audience: {
      '@type': 'Audience',
      audienceType: 'Medicare beneficiaries, Seniors 60+, Caregivers',
    },
  },
];

// FAQPage schema — only if we have FAQs
if (faqs.length > 0) {
  hubSchemas.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    '@id': `https://www.seniorsaudit.com/${canonicalPath}/#faqpage`,
    mainEntity: faqs.map(faq => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  });
}

// Format date for display
const displayDate = new Date(lastUpdated).toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
});

// Tool icon SVG paths
const toolIcons: Record<string, string> = {
  calculator: 'M4 6h16M4 10h16M4 14h8M4 18h8M14 14h6M14 18h6M14 14v4',
  checklist:  'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
  compare:    'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  clock:      'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
  dollar:     'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
};
---

<BaseLayout
  title={pageTitle}
  description={description}
  canonical={`https://www.seniorsaudit.com/${canonicalPath}/`}
  ogImage={ogImage}
  ogType="website"
  schema={hubSchemas}
  breadcrumbs={breadcrumbs}
>
  <!-- Breadcrumb Nav -->
  <nav class="breadcrumb-nav" aria-label="Breadcrumb">
    <ol class="breadcrumb-list" itemscope itemtype="https://schema.org/BreadcrumbList">
      {breadcrumbs.map((crumb, i) => (
        <li class="breadcrumb-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          {i < breadcrumbs.length - 1 ? (
            <>
              <a href={crumb.url} class="breadcrumb-link" itemprop="item">
                <span itemprop="name">{crumb.name}</span>
              </a>
              <span class="breadcrumb-sep" aria-hidden="true">›</span>
            </>
          ) : (
            <span class="breadcrumb-current" itemprop="name" aria-current="page">{crumb.name}</span>
          )}
          <meta itemprop="position" content={String(i + 1)} />
        </li>
      ))}
    </ol>
  </nav>

  <!-- Hub Page Wrapper -->
  <div class="hub-wrapper">

    <!-- ══ HUB HEADER ══════════════════════════════════════ -->
    <header class="hub-header" id="hub-intro">
      <p class="hub-meta">
        Last reviewed by the Seniors Audit research team on <time datetime={lastUpdated}>{displayDate}</time>
        <span class="hub-meta-sep">·</span>
        By {authorName}
      </p>
      <h1 class="hub-h1">{h1}</h1>

      <!-- Quick Answer Block (AEO / Featured Snippet targeting) -->
      <aside class="quick-answer" aria-label="Quick Answer">
        <p class="quick-answer-label">Quick Answer</p>
        <p class="quick-answer-text">{quickAnswer}</p>
      </aside>

      <p class="hub-lead">{leadParagraph}</p>

      <!-- What This Hub Covers -->
      <div class="hub-covers">
        <p class="hub-covers-label">This guide answers:</p>
        <ul class="hub-covers-list">
          {whatThisCovers.map(q => <li>{q}</li>)}
        </ul>
      </div>
    </header>

    <!-- ══ TWO-COLUMN BODY ══════════════════════════════════ -->
    <div class="hub-body">

      <!-- ── Main Content Column ── -->
      <main class="hub-main" id="main-hub-content">

        <!-- Mobile TOC (inline, above content) -->
        {toc.length > 0 && (
          <nav class="toc-mobile" aria-label="On this page (mobile)">
            <p class="toc-heading">On this page</p>
            <ul class="toc-list">
              {toc.map(item => (
                <li><a href={`#${item.id}`} class="toc-link">{item.label}</a></li>
              ))}
            </ul>
          </nav>
        )}

        <!-- Written Body Sections (slot for inline content) -->
        {sections.map(section => (
          <section id={section.id} class="hub-section" aria-labelledby={`heading-${section.id}`}>
            <h2 id={`heading-${section.id}`} class="hub-h2">{section.heading}</h2>
            <Fragment set:html={section.content} />
          </section>
        ))}

        <!-- Slot for additional custom content from page -->
        <slot />

        <!-- ── Article Cards Grid ── -->
        {articles.length > 0 && (
          <section id="articles" class="hub-articles-section" aria-labelledby="articles-heading">
            <h2 id="articles-heading" class="hub-h2">All Guides in This Section</h2>
            <div class="article-grid">
              {articles.map(art => (
                <a href={art.href} class="article-card" aria-label={`Read: ${art.title}`}>
                  <div class="article-card-inner">
                    {art.tag && <span class="article-tag">{art.tag}</span>}
                    {art.isNew && !art.tag && <span class="article-tag article-tag--new">New</span>}
                    <h3 class="article-card-title">{art.title}</h3>
                    <p class="article-card-desc">{art.description}</p>
                    <div class="article-card-meta">
                      {art.readingTime && (
                        <span class="article-card-time">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                            <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                          </svg>
                          {art.readingTime} min read
                        </span>
                      )}
                      <span class="article-card-arrow" aria-hidden="true">Read guide →</span>
                    </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- ── Tool CTA Cards ── -->
        {tools.length > 0 && (
          <section id="tools" class="hub-tools-section" aria-labelledby="tools-heading">
            <h2 id="tools-heading" class="hub-h2">Free Calculators &amp; Tools</h2>
            <p class="hub-tools-intro">These free tools use official 2026 government figures. No sign-up required.</p>
            <div class="tool-grid">
              {tools.map(tool => (
                <a href={tool.href} class="tool-card" aria-label={`Open tool: ${tool.title}`}>
                  <div class="tool-card-icon" aria-hidden="true">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75">
                      <path d={toolIcons[tool.icon ?? 'calculator']} stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                  <div class="tool-card-body">
                    <h3 class="tool-card-title">{tool.title}</h3>
                    <p class="tool-card-desc">{tool.description}</p>
                  </div>
                  <span class="tool-card-cta">Use free tool →</span>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- ── FAQ Accordion ── -->
        {faqs.length > 0 && (
          <section id="faqs" class="hub-faq-section" aria-labelledby="faqs-heading">
            <h2 id="faqs-heading" class="hub-h2">Frequently Asked Questions</h2>
            <dl class="faq-list">
              {faqs.map((faq, i) => (
                <div class="faq-item">
                  <dt>
                    <button
                      class="faq-question"
                      aria-expanded="false"
                      aria-controls={`faq-answer-${i}`}
                      id={`faq-btn-${i}`}
                    >
                      <span>{faq.question}</span>
                      <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <polyline points="6 9 12 15 18 9"/>
                      </svg>
                    </button>
                  </dt>
                  <dd
                    class="faq-answer"
                    id={`faq-answer-${i}`}
                    role="region"
                    aria-labelledby={`faq-btn-${i}`}
                    hidden
                  >
                    <p>{faq.answer}</p>
                  </dd>
                </div>
              ))}
            </dl>
          </section>
        )}

        <!-- ── Related Hubs ── -->
        {relatedHubs.length > 0 && (
          <section class="hub-related" aria-labelledby="related-heading">
            <h2 id="related-heading" class="hub-h2">Related Topic Guides</h2>
            <div class="related-grid">
              {relatedHubs.map(hub => (
                <a href={hub.href} class="related-card">
                  <strong class="related-card-title">{hub.title}</strong>
                  <span class="related-card-desc">{hub.description}</span>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- ── Educational Disclaimer ── -->
        <aside class="hub-disclaimer" role="note" aria-label="Educational disclaimer">
          <strong>Educational Information Only.</strong> This page is published by Seniors Audit for educational purposes only. Nothing here constitutes legal, tax, financial, or medical advice. Always verify current figures at <a href="https://www.medicare.gov" rel="noopener noreferrer" target="_blank">medicare.gov</a> or <a href="https://www.ssa.gov" rel="noopener noreferrer" target="_blank">ssa.gov</a>, and consult a licensed professional for your specific situation.
        </aside>

        <!-- ── Sources ── -->
        {sourcesList.length > 0 && (
          <section class="hub-sources" aria-labelledby="sources-heading">
            <h2 id="sources-heading" class="hub-h2-minor">Sources Used in This Guide</h2>
            <ul class="sources-list">
              {sourcesList.map(src => (
                <li>
                  <a href={src.url} rel="noopener noreferrer" target="_blank" class="source-link">{src.name}</a>
                </li>
              ))}
            </ul>
          </section>
        )}

      </main>

      <!-- ── Sidebar ── -->
      <aside class="hub-sidebar" aria-label="Page navigation and tools">

        <!-- Sticky TOC -->
        {toc.length > 0 && (
          <nav class="toc-sidebar" aria-label="On this page">
            <p class="toc-heading">On this page</p>
            <ul class="toc-list">
              {toc.map(item => (
                <li><a href={`#${item.id}`} class="toc-link">{item.label}</a></li>
              ))}
            </ul>
          </nav>
        )}

        <!-- Featured Tool (first tool in list) -->
        {tools.length > 0 && (
          <div class="sidebar-tool-cta">
            <p class="sidebar-tool-label">Free Tool</p>
            <p class="sidebar-tool-title">{tools[0].title}</p>
            <a href={tools[0].href} class="sidebar-tool-btn">
              Open Calculator →
            </a>
          </div>
        )}

        <!-- Trust Badge -->
        <div class="sidebar-trust">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            <polyline points="9 12 11 14 15 10"/>
          </svg>
          <span>All figures sourced from official U.S. government websites (.gov). Updated for 2026.</span>
        </div>

      </aside>
    </div>
  </div>
</BaseLayout>

<!-- FAQ Accordion Script -->
<script>
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      const answerId = btn.getAttribute('aria-controls');
      const answer = answerId ? document.getElementById(answerId) : null;
      btn.setAttribute('aria-expanded', String(!expanded));
      if (answer) {
        answer.hidden = expanded;
      }
    });
  });

  // Highlight active TOC item on scroll
  const tocLinks = document.querySelectorAll('.toc-link');
  const sections = document.querySelectorAll('section[id], header[id]');

  if (tocLinks.length > 0 && sections.length > 0) {
    const observer = new IntersectionObserver(
      entries => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tocLinks.forEach(link => link.classList.remove('toc-link--active'));
            const active = document.querySelector(`.toc-link[href="#${entry.target.id}"]`);
            if (active) active.classList.add('toc-link--active');
          }
        });
      },
      { rootMargin: '-20% 0px -70% 0px' }
    );
    sections.forEach(s => observer.observe(s));
  }
</script>

<style>
  /* ====================================================
     HubLayout — Component Styles
     Inherits design tokens from global.css
     ==================================================== */

  /* Breadcrumb */
  .breadcrumb-nav {
    padding: var(--space-4) 0;
    max-width: 1200px;
    margin: 0 auto;
    padding-left: var(--space-6);
    padding-right: var(--space-6);
  }
  .breadcrumb-list {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    margin: 0;
    padding: 0;
    font-size: var(--text-sm);
  }
  .breadcrumb-item { display: flex; align-items: center; gap: var(--space-1); }
  .breadcrumb-link { color: var(--color-primary); text-decoration: underline; }
  .breadcrumb-link:hover { color: var(--color-primary-light); }
  .breadcrumb-sep { color: var(--color-text-muted); }
  .breadcrumb-current { color: var(--color-text-secondary); }

  /* Hub Wrapper */
  .hub-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-6) var(--space-16);
  }

  /* Hub Header */
  .hub-header {
    padding: var(--space-8) 0 var(--space-10);
    max-width: 820px;
  }
  .hub-meta {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-4);
  }
  .hub-meta-sep { margin: 0 var(--space-2); color: var(--color-text-muted); }
  .hub-h1 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: var(--font-bold);
    color: var(--color-text);
    line-height: var(--leading-tight);
    margin: 0 0 var(--space-8);
    letter-spacing: -0.02em;
  }

  /* Quick Answer */
  .quick-answer {
    background-color: #0A3D3A;
    color: #FFFFFF;
    border-left: 5px solid #C9933A;
    border-radius: var(--radius-lg);
    padding: var(--space-6) var(--space-8);
    margin: 0 0 var(--space-8);
  }
  .quick-answer-label {
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #C9933A;
    margin: 0 0 var(--space-2);
  }
  .quick-answer-text {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    margin: 0;
    color: #FFFFFF;
  }
  :global([data-theme="dark"]) .quick-answer { background-color: #0D4F4B; }

  /* Lead paragraph */
  .hub-lead {
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
    margin: 0 0 var(--space-8);
  }

  /* What This Covers */
  .hub-covers {
    background: var(--color-background-secondary);
    border-radius: var(--radius-lg);
    padding: var(--space-5) var(--space-6);
    margin: 0 0 var(--space-6);
  }
  .hub-covers-label {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-3);
  }
  .hub-covers-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .hub-covers-list li {
    padding-left: var(--space-6);
    position: relative;
    font-size: var(--text-base);
    line-height: var(--leading-snug);
    color: var(--color-text);
  }
  .hub-covers-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-success);
    font-weight: var(--font-bold);
  }

  /* Two-column body */
  .hub-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    align-items: start;
  }
  @media (min-width: 1024px) {
    .hub-body {
      grid-template-columns: minmax(0, 1fr) 300px;
    }
  }

  /* Hub Main sections */
  .hub-section { margin-bottom: var(--space-12); }
  .hub-h2 {
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    color: var(--color-text);
    border-bottom: 2px solid var(--color-border);
    padding-bottom: var(--space-3);
    margin: 0 0 var(--space-6);
  }
  .hub-h2-minor {
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-4);
  }

  /* Mobile TOC */
  .toc-mobile {
    background: var(--color-background-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5) var(--space-6);
    margin-bottom: var(--space-8);
  }
  @media (min-width: 1024px) { .toc-mobile { display: none; } }

  .toc-heading {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-3);
  }
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .toc-link {
    font-size: var(--text-base);
    color: var(--color-primary);
    text-decoration: none;
    padding: var(--space-1) 0;
    display: block;
    transition: color var(--transition-fast);
    border-left: 3px solid transparent;
    padding-left: var(--space-3);
  }
  .toc-link:hover,
  .toc-link--active {
    color: var(--color-brand-gold);
    border-left-color: var(--color-brand-gold);
  }

  /* Article Cards */
  .hub-articles-section { margin-bottom: var(--space-12); }
  .article-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    gap: var(--space-5);
  }
  .article-card {
    display: flex;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    text-decoration: none;
    transition: box-shadow var(--transition-fast), transform var(--transition-fast), border-color var(--transition-fast);
    min-height: 44px;
  }
  .article-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
    border-color: var(--color-primary);
  }
  .article-card:focus-visible {
    outline: 3px solid var(--color-brand-gold);
    outline-offset: 3px;
  }
  .article-card-inner {
    display: flex;
    flex-direction: column;
    padding: var(--space-6);
    gap: var(--space-3);
    flex: 1;
  }
  .article-tag {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    text-transform: uppercase;
