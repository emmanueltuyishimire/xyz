---
/**
 * privacy-policy.astro
 * Full, publication-ready Privacy Policy for seniorsaudit.com.
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/common/Breadcrumb.astro';

const breadcrumbItems = [
  { label: 'Privacy Policy' }
];

const lastUpdated = 'June 2026';
---

<BaseLayout 
  title="Privacy Policy — Seniors Audit" 
  description="Read the complete privacy policy for seniorsaudit.com. We protect your privacy, do not sell your data, and do not require registration to use our calculators."
>
  <div class="legal-page-container">
    <div class="container">

      <Breadcrumb items={breadcrumbItems} />

      <div class="legal-layout">
        <main class="legal-main">
          <header class="legal-header">
            <h1 class="legal-title">Privacy Policy</h1>
            <p class="legal-meta">Last Updated: {lastUpdated} &bull; seniorsaudit.com</p>
            <div class="legal-summary-box">
              <strong>Plain-English Summary:</strong> We do not sell your data. We do not require you to sign up. All numbers you enter into our calculators stay entirely in your browser and are never sent to our servers. We use minimal, privacy-respecting analytics to understand which pages are helpful.
            </div>
          </header>

          <nav class="legal-toc" aria-label="Table of contents">
            <p class="toc-label">Contents</p>
            <ol class="toc-list">
              <li><a href="#who-we-are">Who We Are</a></li>
              <li><a href="#information-we-collect">Information We Collect</a></li>
              <li><a href="#calculator-privacy">Calculator Privacy</a></li>
              <li><a href="#cookies-analytics">Cookies and Analytics</a></li>
              <li><a href="#contact-form">Contact Form Data</a></li>
              <li><a href="#third-party-links">Third-Party Links</a></li>
              <li><a href="#social-media">Social Media Platforms</a></li>
              <li><a href="#data-security">Data Security</a></li>
              <li><a href="#childrens-privacy">Children's Privacy</a></li>
              <li><a href="#your-rights">Your Rights</a></li>
              <li><a href="#policy-changes">Policy Changes</a></li>
              <li><a href="#contact-us">Contact Us</a></li>
            </ol>
          </nav>

          <section class="legal-body" id="who-we-are">
            <h2>1. Who We Are</h2>
            <p>
              seniorsaudit.com ("Seniors Audit," "we," "us," or "our") is an independent educational website founded and operated by T. Emmanuel We are not affiliated with, endorsed by, or connected to any government agency, including but not limited to the Social Security Administration (SSA), the Internal Revenue Service (IRS), the Centers for Medicare &amp; Medicaid Services (CMS), or the Department of Health and Human Services (HHS).
            </p>
            <p>
              Our website address is: <strong>https://www.seniorsaudit.com</strong>
            </p>
            <p>
              This Privacy Policy describes how we handle information when you visit our website, use our calculators, or contact us. By using our website, you acknowledge that you have read and understood this policy.
            </p>
          </section>

          <section class="legal-body" id="information-we-collect">
            <h2>2. Information We Collect</h2>
            <p>
              We collect the minimum amount of information necessary to operate and improve this website. We categorize information as follows:
            </p>
            <h3>A. Information You Voluntarily Provide</h3>
            <p>
              If you choose to contact us using our contact form or by email, you may provide your name, email address, and the contents of your message. This information is used solely to respond to your inquiry. We do not add you to any mailing list without your explicit consent, and we do not share this information with third parties.
            </p>
            <h3>B. Automatically Collected Technical Information</h3>
            <p>
              When you visit our website, our web server and analytics tools may automatically collect standard technical data that web browsers routinely send, including:
            </p>
            <ul>
              <li>Your Internet Protocol (IP) address (anonymized or truncated where technically possible)</li>
              <li>Browser type and version</li>
              <li>Operating system type</li>
              <li>The page URL you visited</li>
              <li>The date and time of your visit</li>
              <li>The referring page (the page that linked you to ours), if any</li>
            </ul>
            <p>
              This technical data is used only for site performance monitoring, troubleshooting, and understanding general traffic patterns. It is not linked to any personal identity.
            </p>
            <h3>C. Calculator Input Data</h3>
            <p>
              See Section 3 (Calculator Privacy) for a complete explanation of how we handle numbers you enter into our calculators. In short: we do not collect or transmit them.
            </p>
          </section>

          <section class="legal-body" id="calculator-privacy">
            <h2>3. Calculator Privacy</h2>
            <p>
              Our interactive calculators — including tools for Social Security benefits, Medicare IRMAA surcharges, Required Minimum Distributions (RMDs), and other retirement calculations — are designed with a core privacy principle:
            </p>
            <div class="policy-highlight-box">
              <strong>All calculator computations occur entirely within your web browser.</strong> The numbers you enter — your income, your age, your account balances, your benefit estimates — are processed using JavaScript running on your own device. This data is never transmitted to our web servers. We do not store, log, or have access to anything you enter into a calculator.
            </div>
            <p>
              When you close the browser tab or refresh the page, your calculator inputs are cleared. We do not use local storage or session storage to persist your calculator data between visits unless a specific calculator tool explicitly states otherwise and offers you a clear choice.
            </p>
            <p>
              You can verify this behavior by using your browser's developer tools (Network tab) to confirm that no data is being sent to a server when you enter calculator values.
            </p>
          </section>

          <section class="legal-body" id="cookies-analytics">
            <h2>4. Cookies and Analytics</h2>
            <h3>A. What Are Cookies</h3>
            <p>
              Cookies are small text files that websites store on your device to remember preferences or track behavior across visits. There are many types of cookies, ranging from essential functional cookies (needed for the site to work) to targeted advertising cookies (used to build user profiles and serve ads).
            </p>
            <h3>B. Our Cookie Policy</h3>
            <p>
              Seniors Audit does not use targeted advertising cookies. We do not use cookies to build user profiles, retarget you with ads, or track you across other websites. We do not sell your browsing data to advertising networks.
            </p>
            <p>
              We may use the following minimal, privacy-respecting tools:
            </p>
            <ul>
              <li>
                <strong>Cloudflare Analytics or equivalent privacy-first analytics:</strong> We use lightweight analytics to understand aggregate, anonymous information — such as how many visitors viewed a page, which guides are most helpful, and how traffic changes over time. This analytics approach does not use cookies for individual tracking and does not create personal user profiles. No personal identifying information is collected or stored.
              </li>
              <li>
                <strong>Essential functional cookies:</strong> Some basic cookies may be used by our hosting infrastructure for security (e.g., bot protection, rate limiting). These are not used for tracking purposes.
              </li>
            </ul>
            <h3>C. How to Control Cookies</h3>
            <p>
              You can configure your browser to reject all cookies, accept only certain types, or notify you before cookies are stored. Instructions for managing cookies are available in your browser's help documentation. Note that disabling cookies will not affect the functionality of our calculators or guides, as they do not require cookies to operate.
            </p>
          </section>

          <section class="legal-body" id="contact-form">
            <h2>5. Contact Form Data</h2>
            <p>
              If you contact us via our website's contact form or a published email address, we receive your name, email address, and your message. We use this information for the sole purpose of reading and responding to your question.
            </p>
            <p>
              We do not:
            </p>
            <ul>
              <li>Sell your email address or contact details to any third party.</li>
              <li>Share your inquiry with any affiliate, advertiser, or partner.</li>
              <li>Add you to any marketing or newsletter mailing list without your explicit opt-in consent.</li>
            </ul>
            <p>
              Contact messages are retained only as long as reasonably necessary to manage correspondence and are not kept beyond what is operationally needed.
            </p>
          </section>

          <section class="legal-body" id="third-party-links">
            <h2>6. Third-Party Links</h2>
            <p>
              Our website contains links to official government websites (such as SSA.gov, IRS.gov, Medicare.gov, and HHS.gov) and, where relevant, to reputable third-party educational or informational resources. We also link to our social media profiles on platforms including YouTube, Facebook, Medium, Pinterest, and Wikidata.
            </p>
            <p>
              These third-party websites have their own independent privacy policies. We have no control over their content or data practices. We strongly encourage you to review the privacy policy of any website you visit through a link from ours.
            </p>
            <p>
              A link from Seniors Audit to a third-party website does not constitute an endorsement of that site's privacy practices, products, or services.
            </p>
          </section>

          <section class="legal-body" id="social-media">
            <h2>7. Social Media Platforms</h2>
            <p>
              Seniors Audit maintains official, publicly accessible profiles on the following social media platforms:
            </p>
            <ul>
              <li><strong>YouTube:</strong> youtube.com/channel/UCWu0bJddTKd3QFldIcrQiTw</li>
              <li><strong>Facebook:</strong> web.facebook.com/SeniorsAudit</li>
              <li><strong>Medium:</strong> medium.com/@SeniorsAudit</li>
              <li><strong>Pinterest:</strong> pinterest.com/SeniorsAudit</li>
              <li><strong>Wikidata:</strong> wikidata.org/wiki/Q140329700</li>
            </ul>
            <p>
              When you interact with our content on these platforms (such as liking a video, leaving a comment, or sending a direct message), that interaction is subject to the privacy policy of the respective platform — not this Privacy Policy. We encourage you to review the privacy policies of YouTube, Facebook, Medium, Pinterest, and Wikidata independently.
            </p>
            <p>
              We do not embed social media trackers or tracking pixels from these platforms on our website pages.
            </p>
          </section>

          <section class="legal-body" id="data-security">
            <h2>8. Data Security</h2>
            <p>
              We take reasonable and appropriate technical and organizational measures to protect the limited information we do hold (primarily, contact form correspondence) from unauthorized access, disclosure, or loss. Our website uses HTTPS encryption for all connections.
            </p>
            <p>
              However, no system of security is perfect or impenetrable. While we do our best to protect your information, we cannot guarantee the absolute security of any data transmitted over the internet. We encourage you to take steps to protect your own information, such as avoiding the sharing of sensitive personal financial details in contact form messages.
            </p>
          </section>

          <section class="legal-body" id="childrens-privacy">
            <h2>9. Children's Privacy</h2>
            <p>
              Seniors Audit is intended for adult audiences — specifically seniors, retirees, and their caregivers. Our content is not directed toward children under the age of 13. We do not knowingly collect personal information from children under 13. If we learn that we have inadvertently collected personal information from a child under 13, we will promptly delete that information.
            </p>
            <p>
              If you are a parent or guardian and believe your child has provided us with personal information, please contact us at the address listed in Section 12 so we can take appropriate action.
            </p>
          </section>

          <section class="legal-body" id="your-rights">
            <h2>10. Your Rights</h2>
            <p>
              Because we collect very little personal information and do not engage in data sales or profiling, many typical data rights concerns do not apply. Nevertheless, we respect your rights under applicable laws:
            </p>
            <ul>
              <li>
                <strong>Access:</strong> You may request a summary of any personal data we hold about you (which, for most visitors, is nothing beyond any contact form messages you have sent).
              </li>
              <li>
                <strong>Deletion:</strong> You may request that we delete any correspondence or personal information you have shared with us via contact form or email.
              </li>
              <li>
                <strong>Correction:</strong> If you believe any information we hold is inaccurate, you may request that it be corrected.
              </li>
            </ul>
            <p>
              To exercise any of these rights, contact us using the information in Section 12. We will respond within a reasonable timeframe.
            </p>
            <p>
              If you are a resident of California, the European Union, or another jurisdiction with specific data protection laws (such as the CCPA or GDPR), the above rights apply to you. We do not sell personal information as defined by the CCPA.
            </p>
          </section>

          <section class="legal-body" id="policy-changes">
            <h2>11. Changes to This Privacy Policy</h2>
            <p>
              We may update this Privacy Policy from time to time to reflect changes in our practices, technology, or legal requirements. When we make material changes, we will update the "Last Updated" date at the top of this page.
            </p>
            <p>
              We encourage you to review this page periodically. Your continued use of Seniors Audit after any changes become effective constitutes your acceptance of the updated Privacy Policy.
            </p>
          </section>

          <section class="legal-body" id="contact-us">
            <h2>12. Contact Us</h2>
            <p>
              If you have questions, concerns, or requests regarding this Privacy Policy, or if you wish to exercise any of your data rights, please contact us:
            </p>
            <div class="contact-info-box">
              <p><strong>Seniors Audit</strong></p>
              <p>Website: <a href="https://www.seniorsaudit.com">seniorsaudit.com</a></p>
              <p>Contact Page: <a href="/contact/">seniorsaudit.com/contact/</a></p>
            </div>
          </section>

        </main>

        <!-- Sidebar navigation -->
        <aside class="legal-sidebar" aria-label="Related legal pages">
          <div class="sidebar-nav-card">
            <h2 class="sidebar-nav-title">Legal Pages</h2>
            <ul class="sidebar-nav-list">
              <li><a href="/privacy-policy/" class="sidebar-nav-link current" aria-current="page">Privacy Policy</a></li>
              <li><a href="/disclaimer/" class="sidebar-nav-link">General Disclaimer</a></li>
              <li><a href="/terms-of-use/" class="sidebar-nav-link">Terms of Use</a></li>
              <li><a href="/about/" class="sidebar-nav-link">About Seniors Audit</a></li>
              <li><a href="/contact/" class="sidebar-nav-link">Contact Us</a></li>
            </ul>
          </div>
          <div class="sidebar-trust-box">
            <p class="sidebar-trust-headline">Your Privacy Matters</p>
            <ul class="trust-checklist">
              <li>✅ No calculator data sent to servers</li>
              <li>✅ No user accounts required</li>
              <li>✅ No ad-tracking cookies</li>
              <li>✅ No personal data sold</li>
              <li>✅ HTTPS encrypted connections</li>
            </ul>
          </div>
        </aside>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .legal-page-container {
    padding-block: var(--space-8);
  }

  .legal-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-10);
    align-items: start;
  }

  @media (max-width: 900px) {
    .legal-layout {
      grid-template-columns: 1fr;
    }
    .legal-sidebar {
      order: -1;
    }
  }

  .legal-header {
    margin-bottom: var(--space-8);
    border-bottom: 2px solid var(--color-border);
    padding-bottom: var(--space-6);
  }

  .legal-title {
    font-size: var(--text-3xl);
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }

  .legal-meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
  }

  .legal-summary-box {
    background: hsl(186, 50%, 95%);
    border-left: 4px solid var(--color-secondary);
    padding: var(--space-4) var(--space-5);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-text);
  }

  /* Table of Contents */
  .legal-toc {
    background: var(--color-bg-subtle, hsl(210, 25%, 98%));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5) var(--space-6);
    margin-bottom: var(--space-10);
  }

  .toc-label {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-bottom: var(--space-3);
  }

  .toc-list {
    padding-left: var(--space-5);
    margin: 0;
    column-count: 2;
    column-gap: var(--space-6);
  }

  @media (max-width: 600px) {
    .toc-list {
      column-count: 1;
    }
  }

  .toc-list li {
    margin-bottom: var(--space-2);
    font-size: var(--text-sm);
  }

  .toc-list a {
    color: var(--color-secondary-dark);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .toc-list a:hover {
    color: var(--color-primary);
  }

  /* Legal body sections */
  .legal-body {
    margin-bottom: var(--space-10);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .legal-body:last-child {
    border-bottom: none;
  }

  .legal-body h2 {
    font-size: var(--text-xl);
    color: var(--color-primary);
    margin-top: 0;
    margin-bottom: var(--space-4);
    padding-top: var(--space-2);
  }

  .legal-body h3 {
    font-size: var(--text-base);
    color: var(--color-primary-dark);
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
    font-weight: var(--font-semibold);
  }

  .legal-body p {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-4);
  }

  .legal-body ul {
    margin-bottom: var(--space-5);
    padding-left: var(--space-6);
  }

  .legal-body li {
    margin-bottom: var(--space-3);
    line-height: var(--leading-normal);
    font-size: var(--text-base);
  }

  /* Special boxes */
  .policy-highlight-box {
    background: hsl(211, 80%, 96%);
    border: 1px solid hsl(211, 60%, 85%);
    border-left: 4px solid var(--color-primary);
    padding: var(--space-5) var(--space-6);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    margin: var(--space-5) 0;
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-primary-dark);
  }

  .contact-info-box {
    background: var(--color-bg-subtle, hsl(210, 25%, 98%));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5) var(--space-6);
    font-size: var(--text-base);
  }

  .contact-info-box p {
    margin-bottom: var(--space-2);
  }

  .contact-info-box p:last-child {
    margin-bottom: 0;
  }

  /* Sidebar */
  .sidebar-nav-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    margin-bottom: var(--space-5);
    background: var(--color-surface, #fff);
  }

  .sidebar-nav-title {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-top: 0;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .sidebar-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-nav-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    color: var(--color-secondary-dark);
    text-decoration: none;
    transition: background-color 0.15s ease;
    margin-bottom: var(--space-1);
  }

  .sidebar-nav-link:hover,
  .sidebar-nav-link.current {
    background-color: hsl(186, 40%, 92%);
    color: var(--color-primary);
    text-decoration: none;
  }

  .sidebar-nav-link.current {
    font-weight: var(--font-semibold);
  }

  .sidebar-trust-box {
    background: hsl(145, 50%, 95%);
    border: 1px solid hsl(145, 40%, 82%);
    border-radius: var(--radius-md);
    padding: var(--space-5);
  }

  .sidebar-trust-headline {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: hsl(145, 50%, 30%);
    margin-bottom: var(--space-3);
  }

  .trust-checklist {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: var(--text-sm);
    color: hsl(145, 50%, 25%);
  }

  .trust-checklist li {
    margin-bottom: var(--space-2);
    line-height: var(--leading-normal);
  }

  .trust-checklist li:last-child {
    margin-bottom: 0;
  }
</style>
