---
/**
 * index.astro
 * seniorsaudit.com Homepage — Full redesign per master homepage prompt.
 *
 * Emotional arc:
 *   ARRIVAL     → "I see you. I know why you're here."
 *   RECOGNITION → "Yes — that is exactly my situation."
 *   TRUST       → "This place knows what it's talking about."
 *   RELIEF      → "I can find the answer I need here."
 *   ACTION      → "I know what to do next."
 *
 * WCAG 2.2 AA compliant. Senior-optimized typography. No images. No stock photos.
 */

import BaseLayout from '@layouts/BaseLayout.astro';

const today = new Date().toISOString().split('T')[0];
const homepageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://www.seniorsaudit.com/#webpage",
  "name": "Seniors Audit — Plain-English Answers to Social Security, Medicare, and IRS Questions",
  "description": "Free educational guides and calculators for American seniors navigating Social Security, Medicare, IRS notices, and retirement benefits.",
  "url": "https://www.seniorsaudit.com/",
  "datePublished": "2026-06-01",
  "dateModified": today,
  "isPartOf": {
    "@type": "WebSite",
    "@id": "https://www.seniorsaudit.com/#website"
  },
  "about": {
    "@type": "Organization",
    "@id": "https://www.seniorsaudit.com/#organization"
  },
  "author": {
    "@type": "Person",
    "@id": "https://www.seniorsaudit.com/about/emmanuel-t/#person",
    "name": "T. Emmanuel",
    "url": "https://www.seniorsaudit.com/about/emmanuel-t/"
  }
};

// Priority 6 — ItemList schema for calculators section (rich result eligibility)
const toolsItemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Senior Benefits Calculators and Tools",
  "description": "Free calculators and guides for Medicare, Social Security, and IRS questions. No registration required.",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Medicare Part B Late Enrollment Penalty Calculator",
      "url": "https://www.seniorsaudit.com/tools/medicare-late-enrollment-penalty-calculator/",
      "description": "Calculate your permanent Medicare Part B premium surcharge for late enrollment."
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Social Security Break-Even Age Calculator",
      "url": "https://www.seniorsaudit.com/tools/social-security-break-even-calculator/",
      "description": "Find the age at which claiming Social Security early vs. late pays off."
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Medicare IRMAA Surcharge Estimator",
      "url": "https://www.seniorsaudit.com/tools/medicare-irmaa-calculator/",
      "description": "Estimate your income-related Medicare Part B and Part D surcharges."
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": "IRS CP2000 Notice Response Guide",
      "url": "https://www.seniorsaudit.com/tools/irs-cp2000-response-guide/",
      "description": "Step-by-step guide to responding to an IRS CP2000 underreporter notice."
    },
    {
      "@type": "ListItem",
      "position": 5,
      "name": "Required Minimum Distribution (RMD) Calculator",
      "url": "https://www.seniorsaudit.com/tools/rmd-calculator/",
      "description": "Calculate your annual RMD from traditional IRAs and 401(k) accounts."
    },
    {
      "@type": "ListItem",
      "position": 6,
      "name": "Social Security Full Retirement Age Calculator",
      "url": "https://www.seniorsaudit.com/tools/social-security-full-retirement-age-calculator/",
      "description": "Find your Social Security full retirement age based on your birth year."
    }
  ]
};
---

<BaseLayout
  title="Seniors Audit — Clear Answers to Your Social Security, Medicare, and IRS Questions"
  description="Free educational guides and calculators for seniors. Plain-English explanations of Social Security, Medicare, IRS notices, and retirement benefits. Verified against SSA.gov, IRS.gov, and Medicare.gov."
  schema={[homepageSchema, toolsItemListSchema]}
>

  <!-- =============================================
       SECTION 1: HERO — EMPATHY + UTILITY
       Talks to the visitor, not about the site.
       ============================================= -->
  <section class="hero-section" aria-labelledby="hero-title">
    <div class="container">
      <div class="hero-content">

        <!-- Empathy lead-in -->
        <p class="hero-eyebrow">
          If you just received a government letter, have a Medicare question, or are unsure about your Social Security — you are in the right place.
        </p>

        <!-- H1 — names 3 specific topics, promises plain English, respects the visitor -->
        <h1 id="hero-title" class="hero-heading">
          Clear, Honest Answers to Your Social Security, Medicare, and IRS Questions.
        </h1>

        <p class="hero-subheading">
          Written in plain English. Verified against official government sources. Built for Americans who worked their whole lives and deserve straight answers.
        </p>

        <!-- Priority 7: Last-reviewed freshness signal -->
        <p class="hero-last-reviewed" aria-label="Content verification date">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true" style="display:inline;vertical-align:-2px;margin-right:4px;"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M8 4.5v4l2.5 1.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          Site content last verified against official sources in <strong>July 2026</strong>
        </p>

        <!-- Search bar — the primary interactive element -->
        <div class="hero-search-wrapper" role="search">
          <form class="hero-search-form" action="/search/" method="get" aria-label="Search Seniors Audit">
            <label for="hero-search-input" class="sr-only">Search for answers</label>
            <div class="hero-search-bar">
              <input
                id="hero-search-input"
                class="hero-search-input"
                type="search"
                name="q"
                placeholder="Try: 'CP2000 notice' or 'Medicare late penalty' or 'widow Social Security benefit'"
                autocomplete="off"
                spellcheck="false"
                aria-label="Search for your question"
              />
              <button type="submit" class="hero-search-btn" aria-label="Find your answer">
                Find Answer
              </button>
            </div>
          </form>

          <!-- Popular quick-links -->
          <nav class="hero-quick-links" aria-label="Popular topics">
            <span class="hero-quick-label">Popular right now:</span>
            <ul class="hero-quick-list" role="list">
              <li><a href="/tools/medicare-irmaa-calculator/" class="hero-quick-chip">IRMAA Calculator</a></li>
              <li><a href="/tools/medicare-late-enrollment-penalty-calculator/" class="hero-quick-chip">Part B Penalty</a></li>
              <li><a href="/tools/social-security-break-even-calculator/" class="hero-quick-chip">SS Breakeven Age</a></li>
              <li><a href="/tools/irs-cp2000-response-guide/" class="hero-quick-chip">CP2000 Explained</a></li>
              <li><a href="/tools/rmd-calculator/" class="hero-quick-chip">Missed RMD</a></li>
            </ul>
          </nav>
        </div>

        <!-- Trust indicators -->
        <div class="hero-trust-container" role="note">
          <span class="trust-item">
            <span class="trust-dot" aria-hidden="true">●</span>
            Verified against official guidelines from SSA.gov, IRS.gov, and Medicare.gov
          </span>
          <span class="trust-item">
            <span class="trust-dot" aria-hidden="true">●</span>
            Founded by T. Emmanuel
          </span>
          <span class="trust-item">
            <span class="trust-dot" aria-hidden="true">●</span>
            Independent — not affiliated with any government agency
          </span>
          <span class="trust-item trust-item--highlight">
            <span class="trust-dot" aria-hidden="true">🔒</span>
            Always free — no subscription, no account, ever
          </span>
          <span class="trust-item trust-item--highlight">
            <span class="trust-dot" aria-hidden="true">🚫</span>
            We never sell or share your information with insurance companies
          </span>
        </div>

      </div>
    </div>
  </section>


  <!-- =============================================
       SECTION 2: RECOGNITION STRIP
       Names real situations. Creates instant "that's me."
       ============================================= -->
  <section class="recognition-section" aria-labelledby="recognition-title">
    <div class="container">
      <p class="section-eyebrow" id="recognition-title">Why people come to Seniors Audit</p>
      <h2 class="recognition-heading">Do any of these sound familiar?</h2>

      <ul class="recognition-grid" role="list">

        <li class="recog-card" role="listitem">
          <div class="recog-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <h3 class="recog-trigger">A letter arrived from the IRS.</h3>
          <p class="recog-context">You're not sure if you owe money, if it's serious, or what happens if you don't respond in time.</p>
          <a href="/irs/" class="recog-link">See IRS notice guides →</a>
        </li>

        <li class="recog-card" role="listitem">
          <div class="recog-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          </div>
          <h3 class="recog-trigger">Your Medicare premium went up and nobody explained why.</h3>
          <p class="recog-context">An IRMAA surcharge may have been applied to your account based on income from two years ago.</p>
          <a href="/tools/medicare-irmaa-calculator/" class="recog-link">Check your IRMAA →</a>
        </li>

        <li class="recog-card" role="listitem">
          <div class="recog-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <h3 class="recog-trigger">You're trying to decide when to claim Social Security.</h3>
          <p class="recog-context">The timing can mean the difference of tens of thousands of dollars over your lifetime.</p>
          <a href="/tools/social-security-break-even-calculator/" class="recog-link">See the breakeven calculator →</a>
        </li>

        <li class="recog-card" role="listitem">
          <div class="recog-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="recog-trigger">Your spouse passed away and you don't know how benefits work now.</h3>
          <p class="recog-context">Survivor benefits have rules most people never hear about until it's too late.</p>
          <a href="/social-security/" class="recog-link">Explore survivor benefits →</a>
        </li>

        <li class="recog-card" role="listitem">
          <div class="recog-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="recog-trigger">You missed an RMD and now you're worried about the penalty.</h3>
          <p class="recog-context">There is a correction process, and in many cases the penalty can be waived entirely.</p>
          <a href="/tools/rmd-calculator/" class="recog-link">See the RMD guide →</a>
        </li>

        <li class="recog-card" role="listitem">
          <div class="recog-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          </div>
          <h3 class="recog-trigger">You think you might qualify for benefits you've never claimed.</h3>
          <p class="recog-context">Millions of seniors leave money on the table because they don't know what programs exist.</p>
          <a href="/medicaid/" class="recog-link">Explore government benefits →</a>
        </li>

      </ul>
    </div>
  </section>


  <!-- =============================================
       SECTION 3: SIX TOPIC HUBS
       Immediate navigation after recognition.
       ============================================= -->
  <section class="hubs-section" aria-labelledby="hubs-title">
    <div class="container">
      <div class="section-header-center">
        <p class="section-eyebrow">Everything in one place</p>
        <h2 id="hubs-title" class="section-heading">Choose the topic that's on your mind</h2>
        <p class="section-subtext">Each section has plain-English guides, official source citations, and free calculators.</p>
      </div>

      <div class="hubs-grid">

        <a href="/social-security/" class="hub-card hub-card--ss" aria-label="Social Security — claiming age, spousal benefits, and more">
          <div class="hub-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>
          </div>
          <div class="hub-body">
            <h3 class="hub-title">Social Security</h3>
            <p class="hub-desc">Claiming age, spousal benefits, survivor benefits, WEP, overpayments, and SSI.</p>
            <span class="hub-cta" aria-hidden="true">Explore Social Security →</span>
          </div>
        </a>

        <a href="/medicare/" class="hub-card hub-card--med" aria-label="Medicare — IRMAA, Part B penalties, and enrollment windows">
          <div class="hub-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <div class="hub-body">
            <h3 class="hub-title">Medicare</h3>
            <p class="hub-desc">IRMAA surcharges, Part B and Part D penalties, plan comparison, and enrollment windows.</p>
            <span class="hub-cta" aria-hidden="true">Explore Medicare →</span>
          </div>
        </a>

        <a href="/irs/" class="hub-card hub-card--irs" aria-label="IRS Notices and Taxes — what your letter means and what to do">
          <div class="hub-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </div>
          <div class="hub-body">
            <h3 class="hub-title">IRS Notices &amp; Taxes</h3>
            <p class="hub-desc">What your letter means, penalties, RMDs, Social Security taxation, and retirement tax planning.</p>
            <span class="hub-cta" aria-hidden="true">Explore IRS &amp; Taxes →</span>
          </div>
        </a>

        <a href="/medicaid/" class="hub-card hub-card--benefits" aria-label="Government Benefits — savings programs, SNAP, and VA benefits">
          <div class="hub-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect width="20" height="5" x="2" y="7"/><line x1="12" x2="12" y1="22" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
          </div>
          <div class="hub-body">
            <h3 class="hub-title">Government Benefits</h3>
            <p class="hub-desc">Medicare Savings Programs, Extra Help, SNAP for seniors, property tax exemptions, and VA benefits.</p>
            <span class="hub-cta" aria-hidden="true">Explore Benefits →</span>
          </div>
        </a>

        <a href="/retirement/" class="hub-card hub-card--retirement" aria-label="Retirement Income — RMDs, withdrawals, and pension decisions">
          <div class="hub-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
          </div>
          <div class="hub-body">
            <h3 class="hub-title">Retirement Income</h3>
            <p class="hub-desc">RMDs, Roth conversions, withdrawal order, pension decisions, and long-term care planning.</p>
            <span class="hub-cta" aria-hidden="true">Explore Retirement →</span>
          </div>
        </a>

        <a href="/taxes/" class="hub-card hub-card--taxes" aria-label="Taxes in Retirement — how Social Security is taxed and more">
          <div class="hub-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          </div>
          <div class="hub-body">
            <h3 class="hub-title">Fraud &amp; Scam Protection</h3>
            <p class="hub-desc">How to recognize IRS impersonators, Medicare fraud, fake benefit programs, and identity theft.</p>
            <span class="hub-cta" aria-hidden="true">Explore Fraud Protection →</span>
          </div>
        </a>

      </div>
    </div>
  </section>


  <!-- =============================================
       SECTION 4: TOOLS STRIP
       Shows depth of utility. Immediate usefulness.
       ============================================= -->
  <section class="tools-section" aria-labelledby="tools-title">
    <div class="container">
      <div class="section-header-center">
        <p class="section-eyebrow">Free calculators — no registration required</p>
        <h2 id="tools-title" class="section-heading">Most used calculators and tools</h2>
      </div>

      <div class="tools-grid">

        <article class="tool-card">
          <div class="tool-card-top">
            <div class="tool-badge-row">
              <span class="tool-badge tool-badge--updated">Updated for 2026</span>
            </div>
            <h3 class="tool-title">Medicare Part B Late Enrollment Penalty Calculator</h3>
            <p class="tool-desc">Find out exactly how much your late enrollment is costing you — and whether it can be reduced.</p>
          </div>
          <a href="/tools/medicare-late-enrollment-penalty-calculator/" class="tool-link" aria-label="Use the Medicare Part B Penalty Calculator">
            Use this tool →
          </a>
        </article>

        <article class="tool-card">
          <div class="tool-card-top">
            <h3 class="tool-title">Social Security Breakeven Calculator</h3>
            <p class="tool-desc">See the exact age when delaying Social Security starts paying off — based on your specific numbers.</p>
          </div>
          <a href="/tools/social-security-break-even-calculator/" class="tool-link" aria-label="Use the Social Security Breakeven Calculator">
            Use this tool →
          </a>
        </article>

        <article class="tool-card">
          <div class="tool-card-top">
            <div class="tool-badge-row">
              <span class="tool-badge tool-badge--updated">Updated for 2026</span>
            </div>
            <h3 class="tool-title">IRMAA Medicare Surcharge Estimator</h3>
            <p class="tool-desc">Find out if your income will trigger a Medicare premium increase — and how much extra you'll pay.</p>
          </div>
          <a href="/tools/medicare-irmaa-calculator/" class="tool-link" aria-label="Use the IRMAA Surcharge Estimator">
            Use this tool →
          </a>
        </article>

        <article class="tool-card">
          <div class="tool-card-top">
            <h3 class="tool-title">IRS Notice Response Guide</h3>
            <p class="tool-desc">Get a plain-English explanation of what your IRS notice means and a step-by-step guide on what to do.</p>
          </div>
          <a href="/tools/irs-cp2000-response-guide/" class="tool-link" aria-label="Use the IRS Notice Response Guide">
            Use this tool →
          </a>
        </article>

      </div>

      <div class="tools-all-link">
        <a href="/tools/" class="tools-all-btn">See all free calculators and tools →</a>
      </div>
    </div>
  </section>


  <!-- =============================================
       SECTION 5: HOW IT WORKS
       Removes hesitation. Three steps, nothing more.
       ============================================= -->
  <section class="how-section" aria-labelledby="how-title">
    <div class="container">
      <div class="section-header-center">
        <p class="section-eyebrow">Getting started takes less than a minute</p>
        <h2 id="how-title" class="section-heading">How Seniors Audit works</h2>
      </div>

      <div class="steps-row">
        <div class="step-item">
          <div class="step-number" aria-hidden="true">1</div>
          <h3 class="step-title">Tell us what you're dealing with.</h3>
          <p class="step-body">Type your question into the search box, or choose one of the topic areas above. There is no account to create and nothing to pay.</p>
        </div>

        <div class="step-connector" aria-hidden="true"></div>

        <div class="step-item">
          <div class="step-number" aria-hidden="true">2</div>
          <h3 class="step-title">Read the plain-English explanation.</h3>
          <p class="step-body">Every guide explains the rules in language that does not require a tax degree. Real numbers, real examples, and real next steps.</p>
        </div>

        <div class="step-connector" aria-hidden="true"></div>

        <div class="step-item">
          <div class="step-number" aria-hidden="true">3</div>
          <h3 class="step-title">Know exactly what to do.</h3>
          <p class="step-body">Every page ends with a clear action list — what to do, what form to use, who to call, and what the official government source says.</p>
        </div>
      </div>
    </div>
  </section>


  <!-- =============================================
       SECTION 6: TRUST & AUTHORITY (EEAT CORE)
       Named founder. Editorial standards. Source citations.
       ============================================= -->
  <section class="trust-section" aria-labelledby="trust-title">
    <div class="container">
      <div class="trust-grid">

        <!-- Left: Who built this and why -->
        <div class="trust-about">
          <p class="section-eyebrow">About Seniors Audit</p>
          <h2 id="trust-title" class="trust-heading">Built by someone who wanted better answers for the people who deserve them.</h2>
          <p>
            Seniors Audit was founded by T. Emmanuel with one purpose: to give American seniors the plain, honest information that government agencies provide in documents almost nobody can understand.
          </p>
          <p>
            The people who use this site spent their lives working, raising families, paying taxes, and contributing to this country. When they reach retirement, they deserve answers — not bureaucratic language, not vague disclaimers, and not advice designed to sell them something.
          </p>
          <p>
            Every guide, calculator, and notice explainer on this site is verified against the official publications of the Social Security Administration, the Internal Revenue Service, and the Centers for Medicare and Medicaid Services before it is published.
          </p>
          <p class="trust-independence">
            Seniors Audit is independent. It is not affiliated with, endorsed by, or connected to any government agency.
          </p>

          <div class="trust-promise-box">
            <h3 class="trust-promise-heading">Our Promise to You</h3>
            <ul class="trust-promise-list" role="list">
              <li>
                <span aria-hidden="true">✓</span>
