---
/**
 * disclaimer.astro
 * Full, publication-ready General Disclaimer for seniorsaudit.com.
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/common/Breadcrumb.astro';

const breadcrumbItems = [
  { label: 'General Disclaimer' }
];

const lastUpdated = 'June 2026';
---

<BaseLayout 
  title="General Disclaimer — Seniors Audit" 
  description="Read the complete general disclaimer for seniorsaudit.com. We provide educational information only. We are not affiliated with the SSA, IRS, Medicare, or any government agency."
>
  <div class="legal-page-container">
    <div class="container">

      <Breadcrumb items={breadcrumbItems} />

      <div class="legal-layout">
        <main class="legal-main">
          <header class="legal-header">
            <h1 class="legal-title">General Disclaimer</h1>
            <p class="legal-meta">Last Updated: {lastUpdated} &bull; seniorsaudit.com</p>
            <div class="legal-summary-box">
              <strong>Plain-English Summary:</strong> Seniors Audit is an educational resource — not a government agency, law firm, tax office, or financial advisor. Our guides and calculators help you understand government programs. They do not replace professional advice, and the results they produce should be verified against current official sources before making real decisions.
            </div>
          </header>

          <nav class="legal-toc" aria-label="Table of contents">
            <p class="toc-label">Contents</p>
            <ol class="toc-list">
              <li><a href="#educational-purpose">Educational Purposes Only</a></li>
              <li><a href="#no-professional-advice">No Professional Advice</a></li>
              <li><a href="#no-government-affiliation">No Government Affiliation</a></li>
              <li><a href="#accuracy">Accuracy and Currency of Information</a></li>
              <li><a href="#calculators">Calculator Limitations</a></li>
              <li><a href="#individual-circumstances">Individual Circumstances Vary</a></li>
              <li><a href="#limitation-of-liability">Limitation of Liability</a></li>
              <li><a href="#external-links">External Government Links</a></li>
              <li><a href="#no-endorsement">No Product or Service Endorsement</a></li>
              <li><a href="#medical-disclaimer">Medical and Health Disclaimer</a></li>
              <li><a href="#jurisdiction">Jurisdiction</a></li>
              <li><a href="#agreement">Agreement to Terms</a></li>
            </ol>
          </nav>

          <section class="legal-body" id="educational-purpose">
            <h2>1. Educational Purposes Only</h2>
            <p>
              All content on seniorsaudit.com — including but not limited to articles, guides, how-to explanations, interactive calculators, worksheets, comparison tables, and example scenarios — is provided for <strong>general educational and illustrative purposes only</strong>.
            </p>
            <p>
              The content on this website is designed to help seniors, retirees, caregivers, and family members develop a general understanding of how government benefit programs work. It is intended to supplement your knowledge, reduce confusion, and help you formulate better questions to bring to a qualified professional. It is not designed to be the sole basis for any legal, financial, tax, or retirement planning decision.
            </p>
            <p>
              Nothing on this website constitutes a complete or definitive statement of the law or regulations governing any government program. Government rules are complex, change frequently, and may interact with your individual circumstances in ways that a general educational resource cannot fully anticipate.
            </p>
          </section>

          <section class="legal-body" id="no-professional-advice">
            <h2>2. No Professional Advice</h2>
            <p>
              <strong>Seniors Audit does not provide legal, tax, financial, investment, actuarial, or medical advice.</strong>
            </p>
            <p>
              T. Emmanuel, the founder and primary author of this website, is an independent educational researcher and writer. T. Emmanuel is not a licensed attorney, Certified Public Accountant (CPA), Enrolled Agent (EA), Certified Financial Planner (CFP), Registered Investment Advisor (RIA), licensed insurance agent, or any other type of licensed professional advisor. Nothing published on this website should be construed as establishing a professional-client relationship of any kind.
            </p>
            <p>
              Reading an article or using a calculator on this website does not create an attorney-client relationship, a fiduciary duty, an accountant-client relationship, or any other professional relationship between you and Seniors Audit or T. Emmanuel
            </p>
            <p>
              We strongly encourage every user to consult with qualified, licensed professionals for matters specific to their situation:
            </p>
            <ul>
              <li><strong>For tax questions:</strong> Consult a licensed CPA or Enrolled Agent (EA).</li>
              <li><strong>For legal questions:</strong> Consult a licensed attorney admitted to practice in your state.</li>
              <li><strong>For investment and retirement planning:</strong> Consult a licensed financial advisor or Certified Financial Planner (CFP).</li>
              <li><strong>For Medicare enrollment decisions:</strong> Consult a licensed State Health Insurance Assistance Program (SHIP) counselor or Medicare-certified insurance broker.</li>
              <li><strong>For Social Security claiming strategies:</strong> Consult with a Social Security Administration office or a financial professional specializing in Social Security optimization.</li>
            </ul>
          </section>

          <section class="legal-body" id="no-government-affiliation">
            <h2>3. No Government Affiliation</h2>
            <p>
              seniorsaudit.com is a private, independent educational website. <strong>We are not affiliated with, sponsored by, endorsed by, authorized by, or connected to any federal, state, or local government agency.</strong>
            </p>
            <p>
              This expressly includes:
            </p>
            <ul>
              <li>The Social Security Administration (SSA)</li>
              <li>The Internal Revenue Service (IRS)</li>
              <li>The Centers for Medicare &amp; Medicaid Services (CMS)</li>
              <li>The Department of Health and Human Services (HHS)</li>
              <li>The Department of Labor (DOL)</li>
              <li>The Department of Veterans Affairs (VA)</li>
              <li>Any state Medicaid agency or social services department</li>
              <li>Any other federal or state government body</li>
            </ul>
            <p>
              Using this website does not constitute an interaction with any government agency. If you need to file a claim, submit a form, appeal a determination, or take any official action, you must do so directly through the appropriate government agency or its official website (such as SSA.gov, IRS.gov, or Medicare.gov).
            </p>
          </section>

          <section class="legal-body" id="accuracy">
            <h2>4. Accuracy and Currency of Information</h2>
            <p>
              We make every reasonable effort to ensure that the information on this website is accurate, sourced from official government publications, and reflects the most current rules as of the date of publication or last review.
            </p>
            <p>
              However, government benefit rules — including benefit formulas, income thresholds, premium amounts, tax brackets, cost-of-living adjustments (COLAs), and eligibility guidelines — are subject to change through annual administrative updates, congressional legislation, regulatory rulemaking, and judicial decisions. These changes may occur quickly and sometimes without widespread media coverage.
            </p>
            <p>
              <strong>We cannot guarantee that all content on this website is 100% accurate, complete, or up to date at the time you read it.</strong> Before relying on any specific number, figure, or rule for an actual decision, we encourage you to verify it directly on the relevant official government portal.
            </p>
            <p>
              Key official sources for verification include:
            </p>
            <ul>
              <li><strong>Social Security rules and benefit amounts:</strong> SSA.gov</li>
              <li><strong>Medicare premiums and enrollment rules:</strong> Medicare.gov</li>
              <li><strong>IRS tax rules, brackets, and publications:</strong> IRS.gov</li>
              <li><strong>Medicaid eligibility:</strong> Your state's Medicaid agency website</li>
              <li><strong>Required Minimum Distributions:</strong> IRS.gov/retirement-plans</li>
            </ul>
          </section>

          <section class="legal-body" id="calculators">
            <h2>5. Calculator Limitations</h2>
            <p>
              The interactive calculators on Seniors Audit are built using official government formulas as our source material. They are designed to produce estimates that closely mirror what a government agency would calculate under standard circumstances.
            </p>
            <p>
              However, all calculators on this website are <strong>estimation tools</strong>, not official government systems. They have inherent limitations:
            </p>
            <ul>
              <li>
                <strong>Simplified assumptions:</strong> Calculators must make simplifying assumptions to be usable by a general audience. Real-world outcomes may differ if your situation involves uncommon factors such as pension offsets (Windfall Elimination Provision, Government Pension Offset), divorce, disability, multiple earning records, or complex tax situations.
              </li>
              <li>
                <strong>Input accuracy:</strong> Results are only as accurate as the numbers you enter. If you enter estimated or approximate figures, your results will reflect those approximations.
              </li>
              <li>
                <strong>Rule updates:</strong> Formulas and thresholds used in calculators reflect the rules as of the date stated on each calculator page. If rules have changed since that date, results may not reflect the current standard.
              </li>
              <li>
                <strong>No state-specific rules:</strong> Many calculators handle federal rules only. State income taxes, state Medicaid rules, and state-specific benefit adjustments are generally not incorporated.
              </li>
            </ul>
            <p>
              Calculator results should be treated as informational estimates to help you understand how programs work — not as official determinations of your benefit entitlement.
            </p>
          </section>

          <section class="legal-body" id="individual-circumstances">
            <h2>6. Individual Circumstances Vary</h2>
            <p>
              Government benefit programs interact with each person's situation in highly individualized ways. Factors that can significantly affect your actual benefits, taxes, or eligibility include — but are not limited to:
            </p>
            <ul>
              <li>Your complete lifetime earnings history</li>
              <li>Whether you or your spouse have a government pension from work not covered by Social Security</li>
              <li>Your immigration or citizenship status</li>
              <li>Your state of residence and applicable state laws</li>
              <li>Your marital status, including divorce, widowhood, and remarriage history</li>
              <li>Whether you have a disability, and the nature and timing of that disability</li>
              <li>Other income sources and how they interact with benefit rules</li>
              <li>The specific timing of your benefit applications and elections</li>
            </ul>
            <p>
              Because individual circumstances vary so widely, a general educational resource cannot substitute for personalized advice from a professional who knows your full situation.
            </p>
          </section>

          <section class="legal-body" id="limitation-of-liability">
            <h2>7. Limitation of Liability</h2>
            <p>
              To the maximum extent permitted by applicable law, Seniors Audit, its owner, T. Emmanuel, and any contributors to this website <strong>shall not be liable</strong> for any direct, indirect, incidental, consequential, special, or exemplary damages arising out of or in connection with your use of this website, including but not limited to:
            </p>
            <ul>
              <li>Financial losses resulting from decisions made based on information or calculator outputs from this website</li>
              <li>Missed benefit filings, missed deadlines, or enrollment errors</li>
              <li>Tax penalties, underpayments, or incorrect tax filings</li>
              <li>Damages from reliance on outdated or inaccurate information</li>
              <li>Any loss of benefits or income resulting from claims or planning decisions</li>
            </ul>
            <p>
              Your use of this website is entirely at your own discretion and risk. The information provided is offered in good faith as an educational resource, but it comes with no warranty of any kind — expressed or implied — as to its accuracy, completeness, fitness for a particular purpose, or freedom from error.
            </p>
          </section>

          <section class="legal-body" id="external-links">
            <h2>8. External Government Links</h2>
            <p>
              Throughout our guides, we link to official government websites such as SSA.gov, IRS.gov, Medicare.gov, and HHS.gov to help you find primary source documentation. These links are provided as a convenience.
            </p>
            <p>
              We do not control, maintain, or guarantee the accuracy of content on any external website. Government websites occasionally restructure, remove, or update their pages. If a government link is broken or leads to outdated content, please check the agency's website directly.
            </p>
            <p>
              Linking to an official government website does not mean that the government agency endorses, is affiliated with, or has reviewed this website.
            </p>
          </section>

          <section class="legal-body" id="no-endorsement">
            <h2>9. No Product or Service Endorsement</h2>
            <p>
              Seniors Audit does not endorse, recommend, or receive compensation for recommending any specific financial product, insurance policy, Medicare plan, investment service, or legal or financial firm. Any mention of commercial services is for illustrative or educational purposes only.
            </p>
            <p>
              We do not accept paid placements, sponsored content, or affiliate referral fees for financial products or insurance plans. Our editorial decisions are made independently.
            </p>
          </section>

          <section class="legal-body" id="medical-disclaimer">
            <h2>10. Medical and Health Disclaimer</h2>
            <p>
              Some content on this website touches on Medicare and Medicaid, which are health insurance programs. Any such content is strictly educational and explains program structure, eligibility rules, premium costs, and enrollment procedures. It does not constitute medical advice.
            </p>
            <p>
              For any health condition, medical procedure, treatment decision, or prescription drug matter, always consult a licensed physician or qualified healthcare provider. Never delay or disregard professional medical advice based on information you read on this website.
            </p>
          </section>

          <section class="legal-body" id="jurisdiction">
            <h2>11. Jurisdiction</h2>
            <p>
              The content on this website focuses on United States federal government programs and is intended for a United States audience. Information about government programs from other countries is not covered. Rules, income limits, and program specifics described on this website apply under U.S. federal law unless otherwise stated.
            </p>
            <p>
              Nothing on this website constitutes legal advice under the law of any particular state or jurisdiction. State rules (including state income taxes on Social Security benefits, state Medicaid eligibility, and state pension laws) vary significantly and are generally outside the scope of this site's federal-level educational focus.
            </p>
          </section>

          <section class="legal-body" id="agreement">
            <h2>12. Agreement to This Disclaimer</h2>
            <p>
              By accessing and using seniorsaudit.com, you acknowledge that you have read, understood, and agreed to the terms of this General Disclaimer. If you do not agree with any part of this disclaimer, your only recourse is to discontinue use of this website.
            </p>
            <p>
              This disclaimer was last reviewed in {lastUpdated} and applies to all content, tools, guides, and calculators currently published on seniorsaudit.com.
            </p>
          </section>

        </main>

        <!-- Sidebar -->
        <aside class="legal-sidebar" aria-label="Related legal pages">
          <div class="sidebar-nav-card">
            <h2 class="sidebar-nav-title">Legal Pages</h2>
            <ul class="sidebar-nav-list">
              <li><a href="/privacy-policy/" class="sidebar-nav-link">Privacy Policy</a></li>
              <li><a href="/disclaimer/" class="sidebar-nav-link current" aria-current="page">General Disclaimer</a></li>
              <li><a href="/terms-of-use/" class="sidebar-nav-link">Terms of Use</a></li>
              <li><a href="/about/" class="sidebar-nav-link">About Seniors Audit</a></li>
              <li><a href="/contact/" class="sidebar-nav-link">Contact Us</a></li>
            </ul>
          </div>
          <div class="sidebar-key-points">
            <p class="sidebar-key-title">Key Points</p>
            <ul class="key-points-list">
              <li>Educational resource only</li>
              <li>Not government affiliated</li>
              <li>No professional advice given</li>
              <li>Verify numbers with SSA.gov, IRS.gov, or Medicare.gov</li>
              <li>Calculators produce estimates only</li>
            </ul>
          </div>
        </aside>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .legal-page-container {
    padding-block: var(--space-8);
  }

  .legal-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-10);
    align-items: start;
  }

  @media (max-width: 900px) {
    .legal-layout {
      grid-template-columns: 1fr;
    }
    .legal-sidebar {
      order: -1;
    }
  }

  .legal-header {
    margin-bottom: var(--space-8);
    border-bottom: 2px solid var(--color-border);
    padding-bottom: var(--space-6);
  }

  .legal-title {
    font-size: var(--text-3xl);
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }

  .legal-meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
  }

  .legal-summary-box {
    background: hsl(38, 90%, 96%);
    border-left: 4px solid hsl(38, 90%, 55%);
    padding: var(--space-4) var(--space-5);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-text);
  }

  /* Table of Contents */
  .legal-toc {
    background: var(--color-bg-subtle, hsl(210, 25%, 98%));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5) var(--space-6);
    margin-bottom: var(--space-10);
  }

  .toc-label {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-bottom: var(--space-3);
  }

  .toc-list {
    padding-left: var(--space-5);
    margin: 0;
    column-count: 2;
    column-gap: var(--space-6);
  }

  @media (max-width: 600px) {
    .toc-list {
      column-count: 1;
    }
  }

  .toc-list li {
    margin-bottom: var(--space-2);
    font-size: var(--text-sm);
  }

  .toc-list a {
    color: var(--color-secondary-dark);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .toc-list a:hover {
    color: var(--color-primary);
  }

  .legal-body {
    margin-bottom: var(--space-10);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .legal-body:last-child {
    border-bottom: none;
  }

  .legal-body h2 {
    font-size: var(--text-xl);
    color: var(--color-primary);
    margin-top: 0;
    margin-bottom: var(--space-4);
  }

  .legal-body p {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-4);
  }

  .legal-body ul {
    margin-bottom: var(--space-5);
    padding-left: var(--space-6);
  }

  .legal-body li {
    margin-bottom: var(--space-3);
    line-height: var(--leading-normal);
    font-size: var(--text-base);
  }

  /* Sidebar */
  .sidebar-nav-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    margin-bottom: var(--space-5);
    background: var(--color-surface, #fff);
  }

  .sidebar-nav-title {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-top: 0;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .sidebar-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-nav-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    color: var(--color-secondary-dark);
    text-decoration: none;
    transition: background-color 0.15s ease;
    margin-bottom: var(--space-1);
  }

  .sidebar-nav-link:hover,
  .sidebar-nav-link.current {
    background-color: hsl(186, 40%, 92%);
    color: var(--color-primary);
    text-decoration: none;
  }

  .sidebar-nav-link.current {
    font-weight: var(--font-semibold);
  }

  .sidebar-key-points {
    background: hsl(38, 80%, 95%);
    border: 1px solid hsl(38, 70%, 82%);
    border-radius: var(--radius-md);
    padding: var(--space-5);
  }

  .sidebar-key-title {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: hsl(38, 70%, 30%);
    margin-bottom: var(--space-3);
  }

  .key-points-list {
    list-style: disc;
    padding-left: var(--space-5);
    margin: 0;
    font-size: var(--text-sm);
    color: hsl(38, 60%, 25%);
  }

  .key-points-list li {
    margin-bottom: var(--space-2);
    line-height: var(--leading-normal);
  }

  .key-points-list li:last-child {
    margin-bottom: 0;
  }
</style>
