---
/**
 * terms-of-use.astro
 * Full, publication-ready Terms of Use for seniorsaudit.com.
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/common/Breadcrumb.astro';

const breadcrumbItems = [
  { label: 'Terms of Use' }
];

const lastUpdated = 'June 2026';
---

<BaseLayout 
  title="Terms of Use — Seniors Audit" 
  description="Read the complete terms of use for seniorsaudit.com. Understand your rights and responsibilities when using our educational calculators, guides, and content."
>
  <div class="legal-page-container">
    <div class="container">

      <Breadcrumb items={breadcrumbItems} />

      <div class="legal-layout">
        <main class="legal-main">
          <header class="legal-header">
            <h1 class="legal-title">Terms of Use</h1>
            <p class="legal-meta">Last Updated: {lastUpdated} &bull; seniorsaudit.com</p>
            <div class="legal-summary-box">
              <strong>Plain-English Summary:</strong> You're welcome to use everything on this site for your own personal learning — the guides, articles, and calculators are all free. Just don't copy our content to sell it or claim it as your own, and don't misuse the site. That's the heart of it.
            </div>
          </header>

          <nav class="legal-toc" aria-label="Table of contents">
            <p class="toc-label">Contents</p>
            <ol class="toc-list">
              <li><a href="#acceptance">Acceptance of Terms</a></li>
              <li><a href="#permitted-use">Permitted Use</a></li>
              <li><a href="#prohibited-use">Prohibited Use</a></li>
              <li><a href="#intellectual-property">Intellectual Property</a></li>
              <li><a href="#user-submissions">User Submissions</a></li>
              <li><a href="#disclaimer-of-warranties">Disclaimer of Warranties</a></li>
              <li><a href="#limitation-of-liability">Limitation of Liability</a></li>
              <li><a href="#indemnification">Indemnification</a></li>
              <li><a href="#third-party-content">Third-Party Content and Links</a></li>
              <li><a href="#site-availability">Site Availability</a></li>
              <li><a href="#governing-law">Governing Law</a></li>
              <li><a href="#changes-to-terms">Changes to These Terms</a></li>
              <li><a href="#contact">Contact Information</a></li>
            </ol>
          </nav>

          <section class="legal-body" id="acceptance">
            <h2>1. Acceptance of Terms</h2>
            <p>
              By accessing, browsing, or using seniorsaudit.com (the "Website"), you agree to be bound by these Terms of Use ("Terms"), our <a href="/privacy-policy/">Privacy Policy</a>, and our <a href="/disclaimer/">General Disclaimer</a>, all of which are incorporated herein by reference.
            </p>
            <p>
              These Terms constitute a legally binding agreement between you ("User," "you," or "your") and Seniors Audit, operated by T. Emmanuel ("we," "us," or "our"). If you do not agree to these Terms, you must immediately stop using this Website.
            </p>
            <p>
              We reserve the right to update these Terms at any time. Updates will be reflected by a new "Last Updated" date at the top of this page. Your continued use of the Website following such updates constitutes your acceptance of the revised Terms.
            </p>
          </section>

          <section class="legal-body" id="permitted-use">
            <h2>2. Permitted Use</h2>
            <p>
              Subject to these Terms, Seniors Audit grants you a limited, non-exclusive, non-transferable, revocable license to access and use this Website and its content for your personal, non-commercial educational purposes.
            </p>
            <p>
              Under this license, you are permitted to:
            </p>
            <ul>
              <li>Read, view, and use our educational guides, articles, and explanations to improve your personal understanding of government benefit programs.</li>
              <li>Use our interactive calculators to produce estimates for your own personal retirement, benefits, and tax planning purposes.</li>
              <li>Print individual pages or calculator results for your personal reference or to share with a licensed professional you are consulting (such as your CPA or attorney).</li>
              <li>Share links to pages on this website on social media or in personal communications, provided the link is accurate and not misrepresented.</li>
              <li>Quote brief passages from our articles in a personal blog, email, or educational context, with clear attribution to seniorsaudit.com and a link to the original page.</li>
            </ul>
          </section>

          <section class="legal-body" id="prohibited-use">
            <h2>3. Prohibited Use</h2>
            <p>
              The following uses of this Website are strictly prohibited:
            </p>
            <h3>A. Commercial Reproduction and Scraping</h3>
            <ul>
              <li>Reproducing, republishing, selling, licensing, or distributing our editorial content, calculator code, guide text, or any other materials from this Website on any other commercial website, service, publication, or product without our prior written permission.</li>
              <li>Using automated tools, bots, scrapers, or spiders to systematically download, copy, or extract content from this Website.</li>
              <li>Repackaging or redistributing our educational content as your own product or under your own brand.</li>
            </ul>
            <h3>B. Misleading Representations</h3>
            <ul>
              <li>Using our brand name, logo, or any reference to "Seniors Audit" in a way that falsely implies that we have endorsed, verified, or are affiliated with your products, services, advice, or calculations.</li>
              <li>Representing our calculator estimates or educational content as official government determinations of your benefit amount, eligibility, or tax liability.</li>
              <li>Framing or mirroring this Website in a way that suggests you or your organization operates it.</li>
            </ul>
            <h3>C. Technical Misuse</h3>
            <ul>
              <li>Attempting to gain unauthorized access to any part of our systems, server infrastructure, or underlying code.</li>
              <li>Introducing malware, viruses, or malicious code to our Website.</li>
              <li>Performing denial-of-service attacks or any other actions that disrupt or damage the Website's availability or performance.</li>
              <li>Circumventing any security or access controls implemented on this Website.</li>
            </ul>
            <h3>D. Harmful or Illegal Use</h3>
            <ul>
              <li>Using this Website for any purpose that is unlawful under applicable federal, state, or local law.</li>
              <li>Using information from this Website to commit fraud, deception, or any other harmful act toward third parties.</li>
            </ul>
          </section>

          <section class="legal-body" id="intellectual-property">
            <h2>4. Intellectual Property</h2>
            <p>
              All content on this Website — including but not limited to the written text of articles and guides, calculator logic and code, custom graphics and design elements, page layouts, and compilation of educational materials — is the intellectual property of Seniors Audit and T. Emmanuel, and is protected by United States and international copyright laws.
            </p>
            <p>
              Certain factual information referenced on this website (such as government formulas, statutory text, or regulatory thresholds) is in the public domain by virtue of being produced by the U.S. government. Our original expression, organization, explanation, and editorial voice used to present that information is our own intellectual property.
            </p>
            <p>
              The name "Seniors Audit," "seniorsaudit.com," and any associated logos or marks are the property of Seniors Audit. You may not use these names or marks in connection with any product or service, or in any manner that is likely to cause confusion as to affiliation or endorsement.
            </p>
            <p>
              Any permission to quote or excerpt content from this Website (as described in Section 2) does not constitute a waiver of our intellectual property rights. All rights not expressly granted herein are reserved.
            </p>
          </section>

          <section class="legal-body" id="user-submissions">
            <h2>5. User Submissions</h2>
            <p>
              If you submit a question, comment, suggestion, feedback, or other communication to us — whether through our contact form, email, or any social media platform we operate — you grant us a non-exclusive, royalty-free, perpetual, worldwide license to use, reproduce, and incorporate that communication for the purpose of improving our educational content and services.
            </p>
            <p>
              We will not publish your personally identifying information (such as your name or email address) without your consent. However, we may publish anonymized or paraphrased versions of user questions to address common topics in our guides.
            </p>
            <p>
              By submitting a communication, you represent that you have the right to submit it and that it does not infringe on any third party's rights.
            </p>
          </section>

          <section class="legal-body" id="disclaimer-of-warranties">
            <h2>6. Disclaimer of Warranties</h2>
            <p>
              <strong>This Website and all of its content, calculators, and tools are provided "as is" and "as available," without any warranty of any kind, expressed or implied.</strong>
            </p>
            <p>
              To the fullest extent permitted by applicable law, Seniors Audit and T. Emmanuel disclaim all warranties, including but not limited to:
            </p>
            <ul>
              <li>Implied warranties of merchantability or fitness for a particular purpose</li>
              <li>Warranties that the Website will be uninterrupted, error-free, or free from technical defects</li>
              <li>Warranties that information or calculator outputs are accurate, complete, current, or suitable for your specific situation</li>
              <li>Warranties that this Website is free from viruses or other harmful components</li>
            </ul>
            <p>
              We do not warrant that the Website will meet your requirements or that errors will be corrected. You use this Website entirely at your own risk.
            </p>
          </section>

          <section class="legal-body" id="limitation-of-liability">
            <h2>7. Limitation of Liability</h2>
            <p>
              To the maximum extent permitted by applicable law, in no event shall Seniors Audit, T. Emmanuel, or any contributor to this Website be liable for any:
            </p>
            <ul>
              <li>Direct, indirect, incidental, special, consequential, or exemplary damages</li>
              <li>Financial losses arising from decisions made in reliance on information from this Website</li>
              <li>Lost income, lost benefits, tax penalties, or missed government deadlines</li>
              <li>Errors in calculator results that caused you to make incorrect retirement or tax planning decisions</li>
              <li>Damages from Website downtime, technical errors, or data loss</li>
            </ul>
            <p>
              This limitation of liability applies whether the claim is based on warranty, contract, tort (including negligence), or any other legal theory, and regardless of whether we were advised of the possibility of such damages.
            </p>
            <p>
              Some jurisdictions do not allow the exclusion or limitation of certain warranties or liability. In such jurisdictions, our liability is limited to the maximum extent permitted by law.
            </p>
          </section>

          <section class="legal-body" id="indemnification">
            <h2>8. Indemnification</h2>
            <p>
              You agree to indemnify, defend, and hold harmless Seniors Audit, T. Emmanuel, and their respective agents from and against any and all claims, liabilities, damages, losses, costs, and expenses (including reasonable attorneys' fees) arising out of or related to:
            </p>
            <ul>
              <li>Your violation of these Terms of Use</li>
              <li>Your misuse of the Website or its content</li>
              <li>Your violation of any applicable law or third-party right</li>
              <li>Any false or misleading representation you make based on content from this Website</li>
            </ul>
          </section>

          <section class="legal-body" id="third-party-content">
            <h2>9. Third-Party Content and Links</h2>
            <p>
              This Website contains links to third-party websites, including official government websites (SSA.gov, IRS.gov, Medicare.gov) and our social media profiles (YouTube, Facebook, Medium, Pinterest, Wikidata). These links are provided for your convenience and for reference purposes.
            </p>
            <p>
              We do not control the content of any third-party website and are not responsible for its accuracy, legality, or any other aspect of its content. The inclusion of any link does not constitute an endorsement of that website. Your use of any linked third-party website is governed by that website's own terms of use and privacy policy.
            </p>
          </section>

          <section class="legal-body" id="site-availability">
            <h2>10. Site Availability</h2>
            <p>
              We strive to keep this Website available at all times. However, we do not guarantee uninterrupted access. The Website may be temporarily unavailable due to maintenance, technical issues, server outages, or circumstances beyond our control. We are not liable for any inconvenience or loss caused by periods of unavailability.
            </p>
            <p>
              We reserve the right to modify, suspend, or discontinue any feature, page, or calculator on this Website at any time, with or without notice.
            </p>
          </section>

          <section class="legal-body" id="governing-law">
            <h2>11. Governing Law</h2>
            <p>
              These Terms of Use are governed by and construed in accordance with the laws of the United States and the state in which Seniors Audit is primarily operated, without regard to conflicts of law principles. Any dispute arising from these Terms shall be subject to the exclusive jurisdiction of the courts located in that state.
            </p>
            <p>
              If any provision of these Terms is found to be invalid or unenforceable, the remaining provisions will remain in full force and effect. Failure to enforce any provision of these Terms shall not be deemed a waiver of that provision.
            </p>
          </section>

          <section class="legal-body" id="changes-to-terms">
            <h2>12. Changes to These Terms</h2>
            <p>
              We reserve the right to update or revise these Terms of Use at any time. When we make changes, we will update the "Last Updated" date at the top of this page. It is your responsibility to review these Terms periodically.
            </p>
            <p>
              Your continued use of this Website after any changes to these Terms constitutes your acceptance of the updated Terms. If you do not agree to the updated Terms, you must stop using this Website.
            </p>
          </section>

          <section class="legal-body" id="contact">
            <h2>13. Contact Information</h2>
            <p>
              If you have questions about these Terms of Use, or if you wish to request permission for a use of our content not covered in Section 2, please contact us:
            </p>
            <div class="contact-info-box">
              <p><strong>Seniors Audit</strong></p>
              <p>Website: <a href="https://www.seniorsaudit.com">seniorsaudit.com</a></p>
              <p>Contact Page: <a href="/contact/">seniorsaudit.com/contact/</a></p>
            </div>
            <p>
              We will respond to all reasonable inquiries within a reasonable timeframe.
            </p>
          </section>

        </main>

        <!-- Sidebar -->
        <aside class="legal-sidebar" aria-label="Related legal pages">
          <div class="sidebar-nav-card">
            <h2 class="sidebar-nav-title">Legal Pages</h2>
            <ul class="sidebar-nav-list">
              <li><a href="/privacy-policy/" class="sidebar-nav-link">Privacy Policy</a></li>
              <li><a href="/disclaimer/" class="sidebar-nav-link">General Disclaimer</a></li>
              <li><a href="/terms-of-use/" class="sidebar-nav-link current" aria-current="page">Terms of Use</a></li>
              <li><a href="/about/" class="sidebar-nav-link">About Seniors Audit</a></li>
              <li><a href="/contact/" class="sidebar-nav-link">Contact Us</a></li>
            </ul>
          </div>
          <div class="sidebar-permitted-box">
            <p class="sidebar-permitted-title">You May</p>
            <ul class="permitted-list">
              <li>✅ Use calculators for personal planning</li>
              <li>✅ Read and print guides</li>
              <li>✅ Share links to our pages</li>
              <li>✅ Quote short passages with attribution</li>
            </ul>
            <p class="sidebar-permitted-title" style="margin-top: 1rem;">You May Not</p>
            <ul class="prohibited-list">
              <li>❌ Republish content commercially</li>
              <li>❌ Scrape or copy site content</li>
              <li>❌ Use our brand without permission</li>
              <li>❌ Misrepresent calculator results as official</li>
            </ul>
          </div>
        </aside>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .legal-page-container {
    padding-block: var(--space-8);
  }

  .legal-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-10);
    align-items: start;
  }

  @media (max-width: 900px) {
    .legal-layout {
      grid-template-columns: 1fr;
    }
    .legal-sidebar {
      order: -1;
    }
  }

  .legal-header {
    margin-bottom: var(--space-8);
    border-bottom: 2px solid var(--color-border);
    padding-bottom: var(--space-6);
  }

  .legal-title {
    font-size: var(--text-3xl);
    color: var(--color-primary);
    margin-bottom: var(--space-2);
  }

  .legal-meta {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
  }

  .legal-summary-box {
    background: hsl(211, 80%, 96%);
    border-left: 4px solid var(--color-primary);
    padding: var(--space-4) var(--space-5);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-text);
  }

  /* Table of Contents */
  .legal-toc {
    background: var(--color-bg-subtle, hsl(210, 25%, 98%));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5) var(--space-6);
    margin-bottom: var(--space-10);
  }

  .toc-label {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-bottom: var(--space-3);
  }

  .toc-list {
    padding-left: var(--space-5);
    margin: 0;
    column-count: 2;
    column-gap: var(--space-6);
  }

  @media (max-width: 600px) {
    .toc-list {
      column-count: 1;
    }
  }

  .toc-list li {
    margin-bottom: var(--space-2);
    font-size: var(--text-sm);
  }

  .toc-list a {
    color: var(--color-secondary-dark);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .toc-list a:hover {
    color: var(--color-primary);
  }

  .legal-body {
    margin-bottom: var(--space-10);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .legal-body:last-child {
    border-bottom: none;
  }

  .legal-body h2 {
    font-size: var(--text-xl);
    color: var(--color-primary);
    margin-top: 0;
    margin-bottom: var(--space-4);
  }

  .legal-body h3 {
    font-size: var(--text-base);
    color: var(--color-primary-dark);
    margin-top: var(--space-6);
    margin-bottom: var(--space-3);
    font-weight: var(--font-semibold);
  }

  .legal-body p {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-4);
  }

  .legal-body ul {
    margin-bottom: var(--space-5);
    padding-left: var(--space-6);
  }

  .legal-body li {
    margin-bottom: var(--space-3);
    line-height: var(--leading-normal);
    font-size: var(--text-base);
  }

  .contact-info-box {
    background: var(--color-bg-subtle, hsl(210, 25%, 98%));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5) var(--space-6);
    margin: var(--space-4) 0;
    font-size: var(--text-base);
  }

  .contact-info-box p {
    margin-bottom: var(--space-2);
  }

  .contact-info-box p:last-child {
    margin-bottom: 0;
  }

  /* Sidebar */
  .sidebar-nav-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    margin-bottom: var(--space-5);
    background: var(--color-surface, #fff);
  }

  .sidebar-nav-title {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin-top: 0;
    margin-bottom: var(--space-4);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .sidebar-nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-nav-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    color: var(--color-secondary-dark);
    text-decoration: none;
    transition: background-color 0.15s ease;
    margin-bottom: var(--space-1);
  }

  .sidebar-nav-link:hover,
  .sidebar-nav-link.current {
    background-color: hsl(186, 40%, 92%);
    color: var(--color-primary);
    text-decoration: none;
  }

  .sidebar-nav-link.current {
    font-weight: var(--font-semibold);
  }

  .sidebar-permitted-box {
    background: var(--color-bg-subtle, hsl(210, 25%, 98%));
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    font-size: var(--text-sm);
  }

  .sidebar-permitted-title {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .permitted-list,
  .prohibited-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .permitted-list li,
  .prohibited-list li {
    margin-bottom: var(--space-2);
    line-height: var(--leading-normal);
    font-size: var(--text-sm);
    color: var(--color-text);
  }
</style>
