---
export const prerender = false;

/**
 * blog/index.astro
 * Educational blog listing page.
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/common/Breadcrumb.astro';
import Card from '@components/common/Card.astro';
import Badge from '@components/common/Badge.astro';
import { getCollection } from 'astro:content';

const now = new Date();
const allBlogPosts = await getCollection('blog', ({ data }) => {
  return data.draft !== true && new Date(data.publishDate) <= now;
});

const sortedPosts = allBlogPosts.sort((a, b) => {
  return new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime();
});

const breadcrumbItems = [
  { label: 'Blog' }
];
---

<BaseLayout 
  title="Educational Blog — Plain English Guides" 
  description="Explore our complete collection of retirement planning, Social Security, Medicare, and IRS notice guides explained in plain, simple English."
>
  <div class="blog-index-container">
    <div class="container">
      
      <!-- Breadcrumbs -->
      <Breadcrumb items={breadcrumbItems} />

      <!-- Header -->
      <header class="blog-header">
        <h1 class="blog-title">Seniors Audit Educational Blog</h1>
        <p class="blog-desc">
          Step-by-step checklists, worksheets, and analysis updates regarding retirement benefits and government notices.
        </p>
      </header>

      <!-- Grid of blog posts -->
      <main class="blog-posts-section">
        {sortedPosts.length > 0 ? (
          <div class="blog-grid">
            {sortedPosts.map(post => {
              const formattedDate = new Date(post.data.publishDate).toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              });
              return (
                <Card href={`/blog/${post.id}/`} class="blog-post-card">
                  <div class="blog-post-content">
                    <div class="blog-post-meta">
                      <Badge variant="secondary" class="blog-badge">{post.data.category.replace('-', ' ')}</Badge>
                      <span class="blog-date">{formattedDate}</span>
                    </div>
                    <h2 class="blog-post-title">{post.data.title}</h2>
                    <p class="blog-post-desc">{post.data.description}</p>
                    <span class="blog-link-text" aria-hidden="true">Read article &rarr;</span>
                  </div>
                </Card>
              );
            })}
          </div>
        ) : null}
      </main>

    </div>
  </div>
</BaseLayout>

<style>
  .blog-index-container {
    padding-block: var(--space-8);
  }

  .blog-header {
    margin-bottom: var(--space-10);
    max-width: var(--content-width);
  }

  .blog-title {
    font-size: var(--text-3xl);
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .blog-desc {
    font-size: var(--text-lg);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-8);
  }

  .blog-post-card {
    height: 100%;
  }

  .blog-post-content {
    display: flex;
    flex-direction: column;
    height: 100%;
    align-items: flex-start;
  }

  .blog-post-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    margin-bottom: var(--space-3);
  }

  .blog-badge {
    margin-bottom: 0;
  }

  .blog-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .blog-post-title {
    font-size: var(--text-xl);
    font-weight: var(--font-bold);
    color: var(--color-primary);
    margin: 0 0 var(--space-2) 0;
    line-height: var(--leading-tight);
  }

  .blog-post-desc {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-5);
    flex-grow: 1;
  }

  .blog-link-text {
    font-weight: var(--font-bold);
    color: var(--color-secondary);
    font-size: var(--text-sm);
    margin-top: auto;
  }

  .blog-post-card:hover .blog-link-text {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .no-posts-message {
    font-style: italic;
    color: var(--color-text-muted);
  }
</style>
