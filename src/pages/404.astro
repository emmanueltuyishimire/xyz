---
/**
 * 404.astro
 * Friendly 404 Not Found page.
 * Reduces frustration for seniors who land on broken links.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/common/Button.astro';
---

<BaseLayout
  title="Page Not Found — Seniors Audit"
  description="Sorry, the page you were looking for could not be found. Return to the Seniors Audit home page."
  noindex={true}
>
  <div class="not-found-container">
    <div class="container">
      <div class="not-found-content">
        <div class="not-found-code" aria-hidden="true">404</div>
        <h1 class="not-found-title">Page Not Found</h1>
        <p class="not-found-message">
          The page you were looking for doesn't exist or may have moved. Don't worry — use the links below to find what you need.
        </p>
        <div class="not-found-actions">
          <Button href="/" variant="primary">Go to Homepage</Button>
          <Button href="/tools/" variant="secondary">Browse Calculators</Button>
          <Button href="/contact/" variant="ghost">Contact Us</Button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .not-found-container {
    padding-block: var(--space-24);
    min-height: 60vh;
    display: flex;
    align-items: center;
  }

  .not-found-content {
    text-align: center;
    max-width: 560px;
    margin-inline: auto;
  }

  .not-found-code {
    font-size: 7rem;
    font-weight: var(--font-bold);
    color: var(--color-border);
    line-height: 1;
    margin-bottom: var(--space-4);
    letter-spacing: -0.05em;
  }

  .not-found-title {
    font-size: var(--text-3xl);
    color: var(--color-primary);
    margin-bottom: var(--space-4);
  }

  .not-found-message {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-8);
  }

  .not-found-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
