---
import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/common/Breadcrumb.astro';
const breadcrumbItems = [
  { label: 'Senior Health', href: '/senior-health/' },
  { label: 'Memory & Cognitive Health' }
];
---
<BaseLayout
  title="Memory and Cognitive Health for Seniors — Medicare Coverage and Resources | Seniors Audit"
  description="Plain-English guide to memory and cognitive health for seniors including Medicare coverage for assessments and available support resources. Coming soon from Seniors Audit."
>
  <div style="background: var(--color-background-secondary, #F6F8FA); min-height: 60vh; padding: var(--space-16) 0;">
    <div class="container" style="max-width: 800px; margin: 0 auto; padding: 0 var(--space-6); text-align: center;">
      <Breadcrumb items={breadcrumbItems} />
      <div style="font-size: 3rem; margin: var(--space-8) 0;" aria-hidden="true">🧠</div>
      <h1 style="font-size: var(--text-3xl); font-weight: var(--font-bold); color: var(--color-text); margin-bottom: var(--space-6);">Memory &amp; Cognitive Health</h1>
      <p style="font-size: var(--text-lg); color: var(--color-text-secondary); max-width: 600px; margin: 0 auto var(--space-8);">
        This guide is being researched and written. It will cover Medicare coverage for cognitive assessments, what to expect from a diagnosis, and available support resources — all verified against official government health sources.
      </p>
      <p style="font-size: var(--text-base); color: var(--color-text-muted);">
        Explore our other resources: <a href="/medicare/" style="color: var(--color-brand-primary); font-weight: var(--font-bold);">Medicare guides</a> · <a href="/tools/" style="color: var(--color-brand-primary); font-weight: var(--font-bold);">Free calculators</a>
      </p>
    </div>
  </div>
</BaseLayout>
