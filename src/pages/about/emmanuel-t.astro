---
/**
 * emmanuel-t.astro
 * T. Emmanuel's Author profile page (E-E-A-T compliance).
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/common/Breadcrumb.astro';
import Card from '@components/common/Card.astro';

const breadcrumbItems = [
  { label: 'About Us', href: '/about/' },
  { label: 'T. Emmanuel' }
];

// Profile Schema for JSON-LD Person representation
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": "https://www.seniorsaudit.com/about/emmanuel-t/#person",
  "name": "T. Emmanuel",
  "alternateName": "TUYISHIMIRE Emmanuel",
  "url": "https://www.seniorsaudit.com/about/emmanuel-t/",
  "jobTitle": "Founder & Benefits Researcher",
  "worksFor": {
    "@type": "Organization",
    "@id": "https://www.seniorsaudit.com/#organization",
    "name": "Seniors Audit",
    "url": "https://www.seniorsaudit.com"
  },
  "description": "T. Emmanuel is the founder of Seniors Audit. He researches government benefits programs including Social Security, Medicare, and IRS regulations, creating plain-language translation tools and calculators for older adults.",
  "sameAs": [
    "https://www.youtube.com/@SeniorsAudit",
    "https://web.facebook.com/SeniorsAudit"
  ]
};
---

<BaseLayout 
  title="T. Emmanuel — Biography & Profile" 
  description="Learn about T. Emmanuel, the founder and benefits researcher behind Seniors Audit, and read his bio, credentials, and educational goals."
  schema={personSchema}
>
  <div class="profile-page-container">
    <div class="container">
      
      <!-- Breadcrumbs -->
      <Breadcrumb items={breadcrumbItems} />

      <div class="profile-layout-grid">
        
        <!-- Main profile details -->
        <main class="profile-main-content">
          <header class="profile-header-card">
            <div class="profile-avatar-row">
              <div class="avatar-large-wrapper">
                <img
                  src="/Emmanuel.png"
                  alt="T. Emmanuel"
                  class="avatar-large-img"
                  width="96"
                  height="96"
                  loading="eager"
                  decoding="async"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                />
                <div class="avatar-large-fallback" aria-hidden="true" style="display:none;">ET</div>
              </div>
              <div class="title-meta">
                <span class="profile-label">Author & Founder</span>
                <h1 class="profile-name">T. Emmanuel</h1>
                <span class="profile-role">Founder, Seniors Audit</span>
              </div>
            </div>
          </header>

          <section class="profile-bio-section">
            <h2>About T. Emmanuel</h2>
            <p>
              T. Emmanuel is the founder and primary benefits researcher at Seniors Audit. Driven by a passion to make complex government regulations more accessible, he creates tools and resources designed to help seniors, retirees, and caregivers navigate retirement planning with clarity.
            </p>
            <p>
              At Seniors Audit, Emmanuel focuses on breaking down the mathematical formulas and legal language behind programs such as:
            </p>
            <ul>
              <li><strong>Social Security Administration (SSA) formulas</strong> including Full Retirement Age (FRA) rules and spousal benefit limits.</li>
              <li><strong>Medicare rules</strong> including IRMAA premium surcharges, state Medicaid income limits, and Medicare Savings Program qualifiers.</li>
              <li><strong>IRS tax notices</strong> including CP2000 and CP501 guidelines, and Required Minimum Distributions (RMDs) formulas.</li>
            </ul>

            <h2>Philosophy and Values</h2>
            <p>
              "Older Americans shouldn't need a law degree or a CPA certification just to understand their basic retirement benefits. My goal is to build direct, plain-language translation tools that allow seniors to estimate their benefits and understand notices in five minutes or less, reducing planning anxiety."
            </p>
          </section>
        </main>

        <!-- Right: Contact/Trust details -->
        <aside class="profile-sidebar" aria-label="E-E-A-T details">
          <Card class="eeat-card">
            <h2 class="sidebar-card-title">Editorial Standards</h2>
            <p class="sidebar-card-desc">
              All guides and calculators created by T. Emmanuel on Seniors Audit follow strict editorial standards:
            </p>
            <ul class="sidebar-list">
              <li><strong>Official Sources Only:</strong> Every calculation or guide is referenced against official agency guidelines (IRS.gov, SSA.gov, Medicare.gov).</li>
              <li><strong>Plain Language:</strong> We target an 8th-grade reading level to ensure explanations are clean and accessible.</li>
              <li><strong>No Financial Sales:</strong> We do not sell insurance, financial products, or legal services.</li>
            </ul>
          </Card>
        </aside>

      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .profile-page-container {
    padding-block: var(--space-8);
  }

  .profile-layout-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  @media (max-width: 860px) {
    .profile-layout-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Header card style */
  .profile-header-card {
    background-color: var(--color-primary-dark);
    color: var(--color-text-inverse);
    padding: var(--space-8);
    border-radius: var(--radius-xl);
    border-bottom: 4px solid var(--color-secondary);
    margin-bottom: var(--space-8);
  }

  .profile-avatar-row {
    display: flex;
    gap: var(--space-6);
    align-items: center;
  }

  @media (max-width: 600px) {
    .profile-avatar-row {
      flex-direction: column;
      text-align: center;
    }
  }

  .avatar-large-wrapper {
    flex-shrink: 0;
  }

  .avatar-large-img {
    width: 96px;
    height: 96px;
    border-radius: var(--radius-full);
    object-fit: cover;
    border: 4px solid var(--color-secondary-light);
    display: block;
  }

  .avatar-large-fallback {
    width: 96px;
    height: 96px;
    border-radius: var(--radius-full);
    background-color: var(--color-surface);
    color: var(--color-primary-dark);
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 4px solid var(--color-secondary-light);
  }

  .title-meta {
    display: flex;
    flex-direction: column;
    gap: calc(var(--space-1) / 2);
  }

  .profile-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    color: var(--color-accent-light);
    font-weight: var(--font-bold);
    letter-spacing: 0.05em;
  }

  .profile-name {
    font-size: var(--text-3xl);
    margin: 0;
    color: #ffffff;
    line-height: var(--leading-tight);
  }

  .profile-role {
    font-size: var(--text-base);
    color: #cbd5e1;
  }

  /* Bio sections */
  .profile-bio-section h2 {
    font-size: var(--text-2xl);
    color: var(--color-primary);
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
  }

  .profile-bio-section p {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-5);
  }

  .profile-bio-section ul {
    margin-bottom: var(--space-6);
    padding-left: var(--space-6);
  }

  .profile-bio-section li {
    margin-bottom: var(--space-3);
    line-height: var(--leading-normal);
  }

  .profile-bio-section li strong {
    color: var(--color-primary);
  }

  /* Sidebar styling */
  .eeat-card {
    border-color: var(--color-border);
  }

  .sidebar-card-title {
    font-size: var(--text-lg);
    color: var(--color-primary);
    margin-bottom: var(--space-3);
    margin-top: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-bottom: 2px solid var(--color-border);
    padding-bottom: var(--space-2);
  }

  .sidebar-card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-4);
  }

  .sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-list li {
    font-size: var(--text-sm);
    margin-bottom: var(--space-3);
    line-height: var(--leading-normal);
  }

  .sidebar-list strong {
    color: var(--color-primary);
    display: block;
    margin-bottom: calc(var(--space-1) / 2);
  }
</style>
