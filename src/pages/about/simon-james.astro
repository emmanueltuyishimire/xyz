---
/**
 * simon-james.astro
 * U. Simon James's Author profile page (E-E-A-T compliance).
 */

import BaseLayout from '@layouts/BaseLayout.astro';
import Breadcrumb from '@components/common/Breadcrumb.astro';
import Card from '@components/common/Card.astro';

const breadcrumbItems = [
  { label: 'About Us', href: '/about/' },
  { label: 'U. Simon James' }
];

// Profile Schema for JSON-LD Person representation
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "U. Simon James",
  "url": "https://www.seniorsaudit.com/about/simon-james/",
  "jobTitle": "Co-Founder & Educational Researcher",
  "worksFor": {
    "@type": "Organization",
    "name": "Seniors Audit",
    "url": "https://www.seniorsaudit.com"
  },
  "description": "U. Simon James is the co-founder of Seniors Audit. He reviews and researches educational content on government benefits, ensuring every article is accurate, up to date, and written in plain English for seniors and their families."
};
---

<BaseLayout 
  title="U. Simon James — Biography & Profile" 
  description="Learn about U. Simon James, the co-founder and content reviewer behind Seniors Audit, and read his bio, credentials, and educational goals."
  schema={personSchema}
>
  <div class="profile-page-container">
    <div class="container">
      
      <!-- Breadcrumbs -->
      <Breadcrumb items={breadcrumbItems} />

      <div class="profile-layout-grid">
        
        <!-- Main profile details -->
        <main class="profile-main-content">
          <header class="profile-header-card">
            <div class="profile-avatar-row">
              <div class="avatar-large-wrapper">
                <img
                  src="/simon.png"
                  alt="U. Simon James"
                  class="avatar-large-img"
                  width="96"
                  height="96"
                  loading="eager"
                  decoding="async"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                />
                <div class="avatar-large-fallback" aria-hidden="true" style="display:none;">SJ</div>
              </div>
              <div class="title-meta">
                <span class="profile-label">Author & Co-Founder</span>
                <h1 class="profile-name">U. Simon James</h1>
                <span class="profile-role">Co-Founder, Seniors Audit</span>
              </div>
            </div>
          </header>

          <section class="profile-bio-section">
            <h2>About U. Simon James</h2>
            <p>
              U. Simon James is the co-founder, educational researcher, and lead content reviewer at Seniors Audit. With a deep commitment to educational transparency, Simon works to ensure that all calculators, guides, and articles published on the platform adhere to strict E-E-A-T guidelines.
            </p>
            <p>
              At Seniors Audit, Simon coordinates our content auditing pipeline, reviewing complex benefit rules and cross-checking calculations against official government sources:
            </p>
            <ul>
              <li><strong>Social Security Administration (SSA) formulas</strong> including spousal benefit payouts and break-even calculations.</li>
              <li><strong>Medicare guidelines</strong> including premium surcharge structures (IRMAA) and enrollment penalty metrics.</li>
              <li><strong>IRS specifications</strong> regarding RMD distributions and CP2000 notice responses.</li>
            </ul>

            <h2>Philosophy and Values</h2>
            <p>
              "Anxiety is the biggest enemy of smart financial planning. By offering clear, accurate, and completely unbiased information in plain English, we aim to give seniors and their caregivers the peace of mind they deserve when handling their benefits."
            </p>
          </section>
        </main>

        <!-- Right: Contact/Trust details -->
        <aside class="profile-sidebar" aria-label="E-E-A-T details">
          <Card class="eeat-card">
            <h2 class="sidebar-card-title">Editorial Review</h2>
            <p class="sidebar-card-desc">
              All guides and calculators reviewed by U. Simon James on Seniors Audit follow strict standards of accuracy:
            </p>
            <ul class="sidebar-list">
              <li><strong>Double-Verification:</strong> All retirement calculations are double-checked against the latest official government calculators and datasets.</li>
              <li><strong>Clarity Focus:</strong> Ensuring explanations are free of intimidating jargon and confusing vocabulary.</li>
              <li><strong>Independent Outlook:</strong> Keeping our tools entirely educational without any affiliate links or financial product sales.</li>
            </ul>
          </Card>
        </aside>

      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .profile-page-container {
    padding-block: var(--space-8);
  }

  .profile-layout-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-10);
    align-items: start;
  }

  @media (max-width: 860px) {
    .profile-layout-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Header card style */
  .profile-header-card {
    background-color: var(--color-primary-dark);
    color: var(--color-text-inverse);
    padding: var(--space-8);
    border-radius: var(--radius-xl);
    border-bottom: 4px solid var(--color-secondary);
    margin-bottom: var(--space-8);
  }

  .profile-avatar-row {
    display: flex;
    gap: var(--space-6);
    align-items: center;
  }

  @media (max-width: 600px) {
    .profile-avatar-row {
      flex-direction: column;
      text-align: center;
    }
  }

  .avatar-large-wrapper {
    flex-shrink: 0;
  }

  .avatar-large-img {
    width: 96px;
    height: 96px;
    border-radius: var(--radius-full);
    object-fit: cover;
    border: 4px solid var(--color-secondary-light);
    display: block;
  }

  .avatar-large-fallback {
    width: 96px;
    height: 96px;
    border-radius: var(--radius-full);
    background-color: var(--color-surface);
    color: var(--color-primary-dark);
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 4px solid var(--color-secondary-light);
  }

  .title-meta {
    display: flex;
    flex-direction: column;
    gap: calc(var(--space-1) / 2);
  }

  .profile-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-secondary-light);
    font-weight: var(--font-bold);
  }

  .profile-name {
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    color: var(--color-text-inverse);
    margin: 0;
    line-height: 1.2;
  }

  .profile-role {
    font-size: var(--text-base);
    color: hsl(200, 20%, 80%);
  }

  /* Bio sections */
  .profile-bio-section h2 {
    font-size: var(--text-2xl);
    color: var(--color-primary);
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
  }

  .profile-bio-section p {
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .profile-bio-section ul {
    margin-bottom: var(--space-6);
    padding-left: var(--space-6);
  }

  .profile-bio-section li {
    margin-bottom: var(--space-2);
    font-size: var(--text-base);
    line-height: var(--leading-normal);
  }

  /* Sidebar card styling */
  .sidebar-card-title {
    font-size: var(--text-xl);
    color: var(--color-primary);
    margin: 0 0 var(--space-3) 0;
  }

  .sidebar-card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
    line-height: var(--leading-normal);
  }

  .sidebar-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .sidebar-list li {
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    color: var(--color-text);
  }

  .sidebar-list strong {
    display: block;
    color: var(--color-primary-light);
    margin-bottom: calc(var(--space-1) / 2);
  }
</style>
