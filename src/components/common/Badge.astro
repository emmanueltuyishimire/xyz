---
/**
 * Badge.astro
 * Small badge/pill indicator for metadata.
 * 
 * Props:
 *   variant    - 'primary' | 'secondary' | 'accent' | 'success' | 'warning' | 'error' | 'neutral'
 *   class      - Additional custom classes
 */

interface Props {
  variant?: 'primary' | 'secondary' | 'accent' | 'success' | 'warning' | 'error' | 'neutral';
  class?: string;
}

const {
  variant = 'neutral',
  class: className = '',
} = Astro.props;

const classList = `badge badge--${variant} ${className}`.trim();
---

<span class={classList}>
  <slot />
</span>

<style>
  .badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-primary);
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    line-height: 1;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 1px solid transparent;
    white-space: nowrap;
  }

  .badge--primary {
    background-color: hsla(216, 70%, 22%, 0.1);
    color: var(--color-primary);
    border-color: hsla(216, 70%, 22%, 0.2);
  }

  .badge--secondary {
    background-color: hsla(186, 60%, 32%, 0.1);
    color: var(--color-secondary);
    border-color: hsla(186, 60%, 32%, 0.2);
  }

  .badge--accent {
    background-color: hsla(38, 90%, 45%, 0.1);
    color: var(--color-accent-dark);
    border-color: hsla(38, 90%, 45%, 0.2);
  }

  .badge--success {
    background-color: hsla(145, 55%, 30%, 0.1);
    color: var(--color-success);
    border-color: hsla(145, 55%, 30%, 0.2);
  }

  .badge--warning {
    background-color: hsla(38, 95%, 40%, 0.1);
    color: var(--color-warning);
    border-color: hsla(38, 95%, 40%, 0.2);
  }

  .badge--error {
    background-color: hsla(0, 70%, 40%, 0.1);
    color: var(--color-error);
    border-color: hsla(0, 70%, 40%, 0.2);
  }

  .badge--neutral {
    background-color: var(--color-surface-alt);
    color: var(--color-text-muted);
    border-color: var(--color-border);
  }
</style>
