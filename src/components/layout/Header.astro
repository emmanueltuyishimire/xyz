---
/**
 * Header.astro
 * seniorsaudit.com site header.
 * Features:
 * - Sticky on scroll with backdrop blur
 * - Logo + primary navigation
 * - Mobile hamburger menu (no JS framework, vanilla only)
 * - WCAG 2.2 AA: keyboard navigation, ARIA attributes, focus management
 * - "Consistent Help" (WCAG 3.2.6): help link always in same location
 */

const navItems = [
  { label: 'Tools & Calculators', href: '/tools/', hasDropdown: true },
  { label: 'Social Security', href: '/social-security/' },
  { label: 'Medicare', href: '/medicare/' },
  { label: 'IRS Notices', href: '/irs/' },
  { label: 'Retirement', href: '/retirement/' },
  { label: 'Blog', href: '/blog/' },
];

const toolItems = [
  { label: 'Full Retirement Age Calculator', href: '/tools/social-security-full-retirement-age-calculator/', section: 'Social Security' },
  { label: 'Benefits Estimator', href: '/tools/social-security-benefits-estimator/', section: 'Social Security' },
  { label: 'IRMAA Calculator', href: '/tools/medicare-irmaa-calculator/', section: 'Medicare' },
  { label: 'Late Enrollment Penalty', href: '/tools/medicare-late-enrollment-penalty-calculator/', section: 'Medicare' },
  { label: 'RMD Calculator', href: '/tools/rmd-calculator/', section: 'Retirement' },
  { label: 'CP2000 Response Guide', href: '/tools/irs-cp2000-response-guide/', section: 'IRS' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header" role="banner">
  <div class="container">
    <div class="header-inner">
      
      <!-- Logo -->
      <a href="/" class="logo" aria-label="Seniors Audit — Home">
        <img
          src="/logo.png"
          alt="Seniors Audit Logo"
          class="logo-icon"
          width="38"
          height="38"
          loading="eager"
          decoding="async"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='block';"
        />
        <!-- SVG fallback if PNG not found -->
        <svg class="logo-icon logo-icon-fallback" style="display:none;" width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true" focusable="false">
          <rect width="36" height="36" rx="8" fill="hsl(216,70%,22%)"/>
          <path d="M10 26 L18 10 L26 26 M13.5 20 H22.5" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="18" cy="28.5" r="1.5" fill="hsl(38,90%,55%)"/>
        </svg>
        <div class="logo-text">
          <span class="logo-name">Seniors <strong>Audit</strong></span>
          <span class="logo-tagline">Government Benefits Education</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="nav-desktop" aria-label="Main navigation">
        <ul class="nav-list" role="list">
          {navItems.map((item) => (
            <li class="nav-item">
              {item.hasDropdown ? (
                <div class="nav-dropdown-wrapper">
                  <a 
                    href={item.href}
                    class={`nav-link ${currentPath.startsWith(item.href) ? 'nav-link--active' : ''}`}
                    aria-haspopup="true"
                    aria-expanded="false"
                  >
                    {item.label}
                    <svg class="nav-chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
                      <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  </a>
                  <div class="nav-dropdown" role="menu">
                    <div class="nav-dropdown-inner">
                      {toolItems.map((tool) => (
                        <a href={tool.href} class="nav-dropdown-link" role="menuitem">
                          <span class="nav-dropdown-section">{tool.section}</span>
                          <span class="nav-dropdown-label">{tool.label}</span>
                        </a>
                      ))}
                      <a href="/tools/" class="nav-dropdown-all" role="menuitem">
                        View all calculators →
                      </a>
                    </div>
                  </div>
                </div>
              ) : (
                <a 
                  href={item.href}
                  class={`nav-link ${currentPath.startsWith(item.href) ? 'nav-link--active' : ''}`}
                  aria-current={currentPath.startsWith(item.href) ? 'page' : undefined}
                >
                  {item.label}
                </a>
              )}
            </li>
          ))}
        </ul>
      </nav>

      <!-- Header Actions -->
      <div class="header-actions">
        <!-- WCAG 3.2.6 Consistent Help — always in same position -->
        <a href="/contact/" class="help-link" aria-label="Get help — contact us">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
            <circle cx="9" cy="9" r="8" stroke="currentColor" stroke-width="1.5"/>
            <path d="M9 13v-1M9 5a2 2 0 010 4v1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <span>Help</span>
        </a>

        <!-- Mobile Menu Toggle -->
        <button 
          class="mobile-menu-toggle"
          id="mobile-menu-toggle"
          aria-controls="mobile-menu"
          aria-expanded="false"
          aria-label="Open navigation menu"
        >
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Navigation -->
  <nav 
    id="mobile-menu"
    class="nav-mobile"
    aria-label="Mobile navigation"
    aria-hidden="true"
  >
    <ul class="nav-mobile-list" role="list">
      {navItems.map((item) => (
        <li>
          <a 
            href={item.href}
            class={`nav-mobile-link ${currentPath.startsWith(item.href) ? 'nav-mobile-link--active' : ''}`}
            aria-current={currentPath.startsWith(item.href) ? 'page' : undefined}
            tabindex="-1"
          >
            {item.label}
          </a>
        </li>
      ))}
      <li class="nav-mobile-divider"></li>
      <li>
        <a href="/contact/" class="nav-mobile-link" tabindex="-1">
          Contact & Help
        </a>
      </li>
    </ul>
  </nav>
</header>

<style>
  /* Header Shell */
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    background-color: hsla(255, 100%, 100%, 0.95);
    border-bottom: 2px solid var(--color-border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    height: var(--header-height);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--header-height);
    gap: var(--space-6);
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo:hover .logo-name { color: var(--color-secondary); }

  .logo-text {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .logo-name {
    font-size: 1.25rem;
    font-weight: var(--font-normal);
    color: var(--color-primary);
    line-height: 1.1;
    letter-spacing: -0.01em;
    transition: color var(--transition-fast);
  }

  .logo-name strong {
    font-weight: var(--font-bold);
    color: var(--color-secondary);
  }

  .logo-tagline {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  /* Desktop Navigation */
  .nav-desktop {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .nav-list {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    font-size: 0.9375rem;
    font-weight: var(--font-bold);
    color: var(--color-text);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: color var(--transition-fast), background-color var(--transition-fast);
    white-space: nowrap;
  }

  .nav-link:hover {
    color: var(--color-primary);
    background-color: var(--color-surface-alt);
    text-decoration: none;
  }

  .nav-link--active {
    color: var(--color-secondary);
  }

  .nav-chevron {
    transition: transform var(--transition-fast);
  }

  /* Dropdown */
  .nav-dropdown-wrapper {
    position: relative;
  }

  .nav-dropdown {
    position: absolute;
    top: calc(100% + var(--space-3));
    left: 50%;
    transform: translateX(-50%);
    width: 380px;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-xl);
    opacity: 0;
    visibility: hidden;
    transform: translateX(-50%) translateY(-8px);
    transition: opacity var(--transition-fast), transform var(--transition-fast), visibility var(--transition-fast);
    z-index: var(--z-dropdown);
  }

  .nav-dropdown-wrapper:hover .nav-dropdown,
  .nav-dropdown-wrapper:focus-within .nav-dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  .nav-dropdown-wrapper:hover .nav-chevron {
    transform: rotate(180deg);
  }

  .nav-dropdown-inner {
    padding: var(--space-4);
    display: grid;
    gap: var(--space-1);
  }

  .nav-dropdown-link {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background-color var(--transition-fast);
  }

  .nav-dropdown-link:hover {
    background-color: var(--color-surface-alt);
    text-decoration: none;
  }

  .nav-dropdown-section {
    font-size: var(--text-xs);
    font-weight: var(--font-bold);
    color: var(--color-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .nav-dropdown-label {
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--color-text);
  }

  .nav-dropdown-all {
    display: block;
    margin-top: var(--space-2);
    padding: var(--space-3) var(--space-4);
    background-color: var(--color-primary);
    color: var(--color-text-inverse);
    text-decoration: none;
    border-radius: var(--radius-md);
    font-weight: var(--font-bold);
    font-size: var(--text-sm);
    text-align: center;
    transition: background-color var(--transition-fast);
  }

  .nav-dropdown-all:hover {
    background-color: var(--color-primary-light);
    color: var(--color-text-inverse);
    text-decoration: none;
  }

  /* Header Actions */
  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  .help-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: var(--font-bold);
    color: var(--color-text-muted);
    text-decoration: none;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    transition: color var(--transition-fast), background-color var(--transition-fast);
  }

  .help-link:hover {
    color: var(--color-primary);
    background-color: var(--color-surface-alt);
    text-decoration: none;
  }

  /* Mobile Menu Toggle — min 48×48px for WCAG 2.5.8 */
  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: background-color var(--transition-fast);
  }

  .mobile-menu-toggle:hover {
    background-color: var(--color-surface-alt);
  }

  .hamburger-line {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--color-text);
    border-radius: 2px;
    transition: transform var(--transition-normal), opacity var(--transition-normal);
  }

  /* Mobile menu open state */
  .mobile-menu-toggle[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .mobile-menu-toggle[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .mobile-menu-toggle[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile Navigation Panel */
  .nav-mobile {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background-color: var(--color-surface);
    border-bottom: 2px solid var(--color-border);
    box-shadow: var(--shadow-lg);
    max-height: 0;
    overflow: hidden;
    transition: max-height var(--transition-normal);
  }

  .nav-mobile.is-open {
    max-height: 600px;
  }

  .nav-mobile-list {
    list-style: none;
    padding: var(--space-4);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .nav-mobile-link {
    display: block;
    padding: var(--space-4) var(--space-4);
    font-size: var(--text-base);
    font-weight: var(--font-bold);
    color: var(--color-text);
    text-decoration: none;
    border-radius: var(--radius-md);
    min-height: 48px;
    display: flex;
    align-items: center;
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .nav-mobile-link:hover,
  .nav-mobile-link--active {
    background-color: var(--color-surface-alt);
    color: var(--color-primary);
    text-decoration: none;
  }

  .nav-mobile-divider {
    height: 1px;
    background-color: var(--color-border);
    margin: var(--space-2) 0;
  }

  /* Responsive breakpoints */
  @media (max-width: 1024px) {
    .nav-desktop { display: none; }
    .mobile-menu-toggle { display: flex; }
    .nav-mobile { display: block; }
    .help-link span { display: none; }
  }

  @media (max-width: 640px) {
    .logo-tagline { display: none; }
    .logo-icon { width: 30px; height: 30px; }
  }
</style>

<script>
  // Vanilla JS mobile menu — no framework, minimal footprint
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      menu.setAttribute('aria-hidden', String(isOpen));
      menu.classList.toggle('is-open', !isOpen);
      
      // Manage tabindex on mobile links
      const mobileLinks = menu.querySelectorAll<HTMLElement>('[tabindex]');
      mobileLinks.forEach(link => {
        link.setAttribute('tabindex', isOpen ? '-1' : '0');
      });

      // Update aria-label
      toggle.setAttribute('aria-label', isOpen ? 'Open navigation menu' : 'Close navigation menu');
    });

    // Close menu on Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') {
        toggle.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-hidden', 'true');
        menu.classList.remove('is-open');
        toggle.focus();
      }
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      const target = e.target as Node;
      if (!toggle.contains(target) && !menu.contains(target)) {
        toggle.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-hidden', 'true');
        menu.classList.remove('is-open');
      }
    });
  }
</script>
